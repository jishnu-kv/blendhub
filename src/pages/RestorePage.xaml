<Page
    x:Class="BlendHub.Pages.RestorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedRestoreItems" />
    </Page.Resources>

    <Grid Padding="0,24,0,0">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="800" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="HeaderGrid.ColumnDefinitions[1].Width" Value="0" />
                        <Setter Target="ActionPanel.(Grid.Row)" Value="1" />
                        <Setter Target="ActionPanel.(Grid.Column)" Value="0" />
                        <Setter Target="ActionPanel.HorizontalAlignment" Value="Left" />
                        <Setter Target="ActionPanel.Margin" Value="0,16,0,0" />
                        <Setter Target="StatusText.HorizontalAlignment" Value="Left" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="24,0,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Restore Settings"
                    FontSize="28"
                    FontWeight="SemiBold"
                    AutomationProperties.HeadingLevel="Level1" />
            </StackPanel>

            <StackPanel x:Name="ActionPanel" Grid.Row="0" Grid.Column="1" Orientation="Horizontal"
                Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="StatusText" Text="" FontWeight="Medium"
                        HorizontalAlignment="Right" FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="RestoreProgressBar" Value="0" Maximum="100" Height="4"
                        MinWidth="120" IsIndeterminate="False" Opacity="0" />
                </StackPanel>
                <Button x:Name="StartRestoreButton" Content="Start Restore"
                    Style="{StaticResource AccentButtonStyle}" Padding="24,10" FontSize="14"
                    FontWeight="Normal" Click="StartRestoreButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Info Bars -->
        <StackPanel x:Name="InfoBarPanel" Grid.Row="1" Spacing="4" Margin="24,0,24,0">
            <InfoBar x:Name="WarningInfoBar" IsOpen="False" IsClosable="True" Severity="Warning"
                Title="" Message="" Closed="InfoBar_Closed" />
            <InfoBar x:Name="ErrorInfoBar" IsOpen="False" IsClosable="True" Severity="Error"
                Title="" Message="" Closed="InfoBar_Closed" />
            <InfoBar x:Name="SuccessInfoBar" IsOpen="False" IsClosable="True" Severity="Success"
                Title="Restore Complete" Message="" Closed="InfoBar_Closed" />
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
            VerticalContentAlignment="Stretch" Padding="0,0,0,0">
            <StackPanel Spacing="16" Padding="24,0,24,0">

                <StackPanel Spacing="2">
                    <!-- Select Backup -->
                    <controls:SettingsCard x:Name="BackupSelectionCard" Header="Select Backup"
                        Description="Select the backup to restore from.">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7B8;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="BackupNameComboBox" MinWidth="240"
                            PlaceholderText="Select backup..." HorizontalAlignment="Right"
                            SelectionChanged="BackupNameComboBox_SelectionChanged" />
                    </controls:SettingsCard>

                    <!-- Restore Destination -->
                    <controls:SettingsCard x:Name="RestoreDestinationCard"
                        Header="Restore Destination"
                        Description="Choose the installed Blender version you want to restore these settings to.">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8DE;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="TargetVersionComboBox" MinWidth="200"
                            DisplayMemberPath="DisplayName"
                            SelectionChanged="TargetVersionComboBox_SelectionChanged" />
                    </controls:SettingsCard>

                    <!-- Items to Include -->
                    <controls:SettingsExpander x:Name="ItemsExpander" Header="Items to Include"
                        Description="Select which parts of the configuration to restore."
                        IsExpanded="True">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8A4;" />
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="60,16" CornerRadius="0" Margin="0,0,0,0">
                                <ItemsRepeater x:Name="RestoreItemsRepeater"
                                    ItemsSource="{Binding Source={StaticResource GroupedRestoreItems}}"
                                    HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="88" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Stretch" Margin="0">
                                                <TextBlock Text="{Binding Key}"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Margin="0,0,0,12"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                                <ItemsRepeater ItemsSource="{Binding Items}">
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate
                                                            x:DataType="models:ConfigItemViewModel">
                                                            <CheckBox Content="{x:Bind Name}"
                                                                IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                IsEnabled="{x:Bind IsExists}"
                                                                Margin="0,2,0,2"
                                                                ToolTipService.ToolTip="{x:Bind TooltipText}" />
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
