<Window
    x:Class="BlendHub.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Progress Indicator -->
        <StackPanel Grid.Row="0" Padding="32,24,32,16">
            <TextBlock 
                x:Name="StepTitleText"
                Text="Step 1 of 4: Your Name"
                FontSize="20"
                FontWeight="SemiBold"
                Margin="0,0,0,8" />
            
            <ProgressBar 
                x:Name="ProgressIndicator"
                Value="25"
                Maximum="100"
                Height="4"
                Margin="0,8,0,0" />
        </StackPanel>

        <!-- Step Content -->
        <ScrollViewer 
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            Padding="32,0,32,32">
            <StackPanel HorizontalAlignment="Stretch" Margin="32,0,32,32">
                    
                    <!-- Step 1: Username -->
                    <StackPanel x:Name="Step1Panel" Visibility="Visible">
                        <TextBlock 
                            Text="Welcome to BlendHub! Let's start with your name."
                            FontSize="16"
                            TextWrapping="Wrap"
                            Margin="0,0,0,24"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        
                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                            <StackPanel>
                                <TextBlock 
                                    Text="Your Name" 
                                    FontSize="18"
                                    FontWeight="Medium"
                                    Margin="0,0,0,8" />
                                <TextBlock 
                                    Text="This will be used to personalize your BlendHub experience."
                                    FontSize="14"
                                    Margin="0,0,0,12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    TextWrapping="Wrap" />
                                
                                <TextBox 
                                    x:Name="UsernameTextBox"
                                    PlaceholderText="Enter your name"
                                    Text="{x:Bind Username, Mode=TwoWay}"
                                    Margin="0,0,0,8" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Step 2: Theme -->
                    <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                        <TextBlock 
                            Text="Choose how you want BlendHub to look and feel."
                            FontSize="16"
                            TextWrapping="Wrap"
                            Margin="0,0,0,24"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        
                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                            <StackPanel>
                                <TextBlock 
                                    Text="Choose Your Theme" 
                                    FontSize="18"
                                    FontWeight="Medium"
                                    Margin="0,0,0,8" />
                                <TextBlock 
                                    Text="Select how you want BlendHub to look and feel."
                                    FontSize="14"
                                    Margin="0,0,0,12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    TextWrapping="Wrap" />
                                
                                <StackPanel Spacing="12">
                                    <RadioButton 
                                        x:Name="SystemThemeRadio"
                                        Content="Use system theme"
                                        GroupName="Theme"
                                        IsChecked="True"
                                        Checked="SystemThemeRadio_Checked" />
                                    <RadioButton 
                                        x:Name="LightThemeRadio"
                                        Content="Light theme"
                                        GroupName="Theme"
                                        Checked="LightThemeRadio_Checked" />
                                    <RadioButton 
                                        x:Name="DarkThemeRadio"
                                        Content="Dark theme"
                                        GroupName="Theme"
                                        Checked="DarkThemeRadio_Checked" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Step 3: Backup Location -->
                    <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                        <TextBlock 
                            Text="Choose where your project backups will be stored."
                            FontSize="16"
                            TextWrapping="Wrap"
                            Margin="0,0,0,24"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        
                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                            <StackPanel>
                                <TextBlock 
                                    Text="Backup Location" 
                                    FontSize="18"
                                    FontWeight="Medium"
                                    Margin="0,0,0,8" />
                                <TextBlock 
                                    Text="Choose where your project backups will be stored."
                                    FontSize="14"
                                    Margin="0,0,0,12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    TextWrapping="Wrap" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox 
                                        x:Name="BackupLocationTextBox"
                                        Text="{x:Bind BackupLocation, Mode=TwoWay}"
                                        IsReadOnly="True"
                                        Margin="0,0,12,0" />
                                    
                                    <Button 
                                        x:Name="BrowseBackupButton"
                                        Content="Browse..."
                                        Grid.Column="1"
                                        Click="BrowseBackupButton_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Step 4: Blender Installations -->
                    <StackPanel x:Name="Step4Panel" Visibility="Collapsed">
                        <TextBlock 
                            Text="We found these Blender installations on your system. You can add more later."
                            FontSize="16"
                            TextWrapping="Wrap"
                            Margin="0,0,0,24"
                            Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        
                        <Border 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                            <StackPanel>
                                <TextBlock 
                                    Text="Blender Installations" 
                                    FontSize="18"
                                    FontWeight="Medium"
                                    Margin="0,0,0,8" />
                                <TextBlock 
                                    Text="We found these Blender installations on your system. You can add more later."
                                    FontSize="14"
                                    Margin="0,0,0,12"
                                    Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                    TextWrapping="Wrap" />
                                
                                <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="DetectedBlendersPanel" Spacing="4">
                                        <!-- Detected blenders will be added here programmatically -->
                                    </StackPanel>
                                </ScrollViewer>
                                
                                <Button 
                                    x:Name="AddBlenderButton"
                                    Content="Add Blender Installation"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Margin="0,12,0,0"
                                    Click="AddBlenderButton_Click" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        <!-- Navigation Buttons -->
        <Border 
            Grid.Row="2"
            Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
            Padding="32,16,32,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <Button 
                    x:Name="SkipButton"
                    Content="Skip Setup"
                    Style="{StaticResource DefaultButtonStyle}"
                    Grid.Column="0"
                    Click="SkipSetupButton_Click" />
                
                <Button 
                    x:Name="PreviousButton"
                    Content="Previous"
                    Style="{StaticResource DefaultButtonStyle}"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Click="PreviousButton_Click"
                    IsEnabled="False" />
                
                <Button 
                    x:Name="NextButton"
                    Content="Next"
                    Style="{StaticResource AccentButtonStyle}"
                    Grid.Column="2"
                    Click="NextButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
