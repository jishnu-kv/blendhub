<Page
    x:Class="BlendHub.Pages.ProjectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:custom="using:BlendHub.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:GroupHeaderMarginConverter x:Key="GroupHeaderMarginConverter" />
        <CollectionViewSource x:Name="GroupedProjects" IsSourceGrouped="True" />
    </Page.Resources>
 
    <Grid x:Name="RootGrid"
          AllowDrop="True"
          DragOver="RootGrid_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Fixed Header Section -->
        <StackPanel Grid.Row="0" Spacing="0" Padding="36,36,36,0">
            <!-- Header -->
            <Grid ColumnDefinitions="*, Auto" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Uid="ProjectPage_Title"
                           Style="{StaticResource TitleTextBlockStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Grid.Row="1"
                           x:Uid="ProjectPage_Subtitle"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0" />
                <Button x:Name="CreateProjectBtn" 
                        Grid.Column="1"
                        Grid.RowSpan="2"
                        Click="ShowDialog_Click" 
                        Style="{StaticResource AccentButtonStyle}"
                        Height="36"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="BtnNewProject"
                        AutomationProperties.Name="New Project">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock x:Uid="ProjectPage_NewProjectButton" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Dynamic Content Area (Progress, InfoBar, and List Header) -->
            <StackPanel Margin="0,28,0,0" Spacing="12">
                <!-- Progress Bar -->
                <StackPanel x:Name="CreatingProgressPanel"
                            Visibility="{x:Bind ViewModel.IsCreating, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" 
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center"
                            Margin="0">
                    <ProgressBar Width="130" IsIndeterminate="True" ShowPaused="False" ShowError="False" />
                    <TextBlock x:Name="ProgressText" Text="{x:Bind ViewModel.CreatingProgressText, Mode=OneWay}" VerticalAlignment="Center" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Feedback -->
                <InfoBar x:Name="ProjectSuccessInfoBar"
                         IsOpen="{x:Bind ViewModel.IsSuccessInfoBarOpen, Mode=TwoWay}"
                         Visibility="{x:Bind ViewModel.IsSuccessInfoBarOpen, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Closed="ProjectSuccessInfoBar_Closed"
                         Severity="Success"
                         Title="{x:Bind ViewModel.SuccessInfoBarTitle, Mode=OneWay}"
                         Message="{x:Bind ViewModel.SuccessInfoBarMessage, Mode=OneWay}"
                         Margin="0">
                     <InfoBar.ActionButton>
                         <Button Content="Open Project" Click="OpenProject_Click" AutomationProperties.AutomationId="BtnOpenCreatedProject" AutomationProperties.Name="Open Project" />
                     </InfoBar.ActionButton>
                 </InfoBar>

                <!-- Projects List Header with Search and Sort -->
                <StackPanel x:Name="ProjectsListContainer" Spacing="8" Margin="0" Visibility="{x:Bind ViewModel.IsProjectsListContainerVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- Section Header with Search and Sort -->
                <Grid x:Name="ProjectsHeaderGrid" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left side: Search and Refresh -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <AutoSuggestBox x:Name="SearchTextBox" 
                                       Width="280"
                                       VerticalAlignment="Center"
                                       x:Uid="ProjectPage_SearchTextBox"
                                       Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                                       AutomationProperties.AutomationId="SearchTextBoxProjects"
                                       AutomationProperties.Name="Search Projects">
                            <AutoSuggestBox.QueryIcon>
                                <FontIcon Glyph="&#xE721;" FontSize="14" />
                            </AutoSuggestBox.QueryIcon>
                        </AutoSuggestBox>
                        
                        <Button x:Name="RefreshProjectsButton" 
                                Style="{StaticResource DefaultButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="{x:Bind ViewModel.RefreshProjectsAsync}"
                                ToolTipService.ToolTip="Refresh Projects"
                                VerticalAlignment="Center"
                                AutomationProperties.AutomationId="BtnRefreshProjects"
                                AutomationProperties.Name="Refresh Projects">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    
                    <!-- Right side: Sort Menu -->
                    <Button x:Name="SortButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            ToolTipService.ToolTip="Sort"
                            AutomationProperties.AutomationId="BtnSortProjects"
                            AutomationProperties.Name="Sort Projects">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8CB;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock x:Name="SortButtonText" Text="{x:Bind ViewModel.SortButtonText, Mode=OneWay}" VerticalAlignment="Center" />
                            <FontIcon Glyph="&#xE70D;" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <RadioMenuFlyoutItem x:Name="SortFieldDateItem" 
                                                     Text="Date Created" 
                                                     GroupName="SortFieldGroup"
                                                     IsChecked="True"
                                                     Tag="Date"
                                                     Click="SortFieldItem_Click"
                                                     AutomationProperties.AutomationId="SortFieldDateItem"
                                                     AutomationProperties.Name="Sort by Date Created"/>
                                <RadioMenuFlyoutItem x:Name="SortFieldModifiedItem" 
                                                     Text="Date Modified" 
                                                     GroupName="SortFieldGroup"
                                                     Tag="Modified"
                                                     Click="SortFieldItem_Click"
                                                     AutomationProperties.AutomationId="SortFieldModifiedItem"
                                                     AutomationProperties.Name="Sort by Date Modified"/>
                                <RadioMenuFlyoutItem x:Name="SortFieldNameItem" 
                                                     Text="Name" 
                                                     GroupName="SortFieldGroup"
                                                     Tag="Name"
                                                     Click="SortFieldItem_Click"
                                                     AutomationProperties.AutomationId="SortFieldNameItem"
                                                     AutomationProperties.Name="Sort by Name"/>
                                <MenuFlyoutSeparator/>
                                <RadioMenuFlyoutItem x:Name="SortOrderAscItem" 
                                                     Text="Ascending" 
                                                     GroupName="SortOrderGroup"
                                                     Tag="Asc"
                                                     Click="SortOrderItem_Click"
                                                     AutomationProperties.AutomationId="SortOrderAscItem"
                                                     AutomationProperties.Name="Sort Ascending"/>
                                <RadioMenuFlyoutItem x:Name="SortOrderDescItem" 
                                                     Text="Descending" 
                                                     GroupName="SortOrderGroup"
                                                     IsChecked="True"
                                                     Tag="Desc"
                                                     Click="SortOrderItem_Click"
                                                     AutomationProperties.AutomationId="SortOrderDescItem"
                                                     AutomationProperties.Name="Sort Descending"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </StackPanel>
        </StackPanel>
    </StackPanel>

        <!-- Projects List -->
        <ListView x:Name="ProjectsList"
                  Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.Projects, Mode=OneWay}"
                  SelectionMode="None"
                  HorizontalAlignment="Stretch"
                  Padding="36,8,36,16"
                  Visibility="{x:Bind ViewModel.IsProjectsListVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                  AutomationProperties.AutomationId="ListAllProjects"
                  AutomationProperties.Name="All Projects">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Project">
                    <custom:ProjectCardView Project="{x:Bind}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Grouped Categorized Projects List (Sticky Header) -->
        <ListView x:Name="CategorizedProjectsList"
                  Grid.Row="1"
                  ItemsSource="{Binding Source={StaticResource GroupedProjects}}"
                  SelectionMode="None"
                  HorizontalAlignment="Stretch"
                  Padding="36,8,36,16"
                  Visibility="{x:Bind ViewModel.IsCategorizedProjectsListVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"
                  AutomationProperties.AutomationId="ListCategorizedProjects"
                  AutomationProperties.Name="Categorized Projects">
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <Style TargetType="ListViewHeaderItem">
                            <Setter Property="Padding" Value="0,16,0,8" />
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewHeaderItem">
                                        <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Key}" 
                                        Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                                        FontWeight="Bold"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Project">
                    <custom:ProjectCardView Project="{x:Bind}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- No Search Results Message -->
        <StackPanel x:Name="NoSearchResultsPanel"
                    Grid.Row="1"
                    Spacing="12"
                    Padding="24"
                    MaxWidth="400"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsNoSearchResultsVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            <FontIcon Glyph="&#xE721;" 
                      FontSize="36" 
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" 
                      Margin="0,0,0,8" />
            <TextBlock x:Uid="ProjectPage_NoResultsTitle" 
                       Style="{StaticResource SubtitleTextBlockStyle}" 
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Uid="ProjectPage_NoResultsDescription" 
                       Style="{StaticResource BodyTextBlockStyle}" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                       TextAlignment="Center" 
                       TextWrapping="Wrap" />
            <Button x:Uid="ProjectPage_ClearSearchBtn" 
                    Click="{x:Bind ViewModel.ClearSearch}" 
                    Style="{StaticResource DefaultButtonStyle}" 
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0"
                    AutomationProperties.AutomationId="BtnClearSearch"
                    AutomationProperties.Name="Clear Search" />
        </StackPanel>

        <!-- Empty Projects View (Visible only when no projects exist) -->
        <Grid x:Name="DropZone"
              Grid.Row="1"
              AllowDrop="True"
              DragOver="DropZone_DragOver"
              Drop="DropZone_Drop"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Padding="36"
              Visibility="{x:Bind ViewModel.IsDropZoneVisible, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24" MaxWidth="480">
                <Image Source="ms-appx:///Assets/empty_project.png"
                       MaxHeight="260"
                       MaxWidth="340"
                       HorizontalAlignment="Center"
                       Stretch="Uniform" />

                <StackPanel Spacing="8">
                    <TextBlock x:Uid="ProjectPage_EmptyTitle"
                               Style="{StaticResource BodyLargeTextBlockStyle}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    
                    <TextBlock x:Uid="ProjectPage_EmptyDescription"
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button x:Name="BrowseProjectBtn"
                        Click="BrowseProjectBtn_Click"
                        Style="{StaticResource DefaultButtonStyle}"
                        Height="36"
                        Padding="16,0"
                        HorizontalAlignment="Center"
                        AutomationProperties.AutomationId="BtnImportFolder"
                        AutomationProperties.Name="Import Existing Folder">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                        <TextBlock x:Uid="ProjectPage_EmptyImportBtn" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Full-Page Drag Overlay -->
        <Grid x:Name="DragOverlay"
              Grid.RowSpan="2"
              Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
              Visibility="Collapsed"
              Canvas.ZIndex="100"
              AllowDrop="True"
              DragOver="DragOverlay_DragOver"
              DragLeave="DragOverlay_DragLeave"
              Drop="DragOverlay_Drop">
            <Grid Margin="24">
                <Rectangle Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                           StrokeThickness="2"
                           StrokeDashArray="3,3"
                           RadiusX="8"
                           RadiusY="8"
                           Fill="Transparent"
                           Margin="0"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <FontIcon Glyph="&#xE8E5;" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    <TextBlock x:Uid="ProjectPage_DragOverlayTitle"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
