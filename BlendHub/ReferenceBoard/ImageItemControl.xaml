<local:BoardItemBase
    x:Class="BlendHub.ReferenceBoard.ImageItemControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.ReferenceBoard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    UseFloatingToolbar="False">

    <Grid>
        <Image x:Name="MainImage" Stretch="Uniform" HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1" />
            </Image.RenderTransform>
        </Image>
    </Grid>

    <local:BoardItemBase.ItemSpecificToolbarContent>
        <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Width="32" Height="32" Padding="0" ToolTipService.ToolTip="Flip Horizontal"
                Background="Transparent" BorderThickness="0" Click="FlipHorizontal_Click">
                <Viewbox Width="18" Height="18">
                    <Canvas Width="24" Height="24">
                        <Path Data="{StaticResource IconPathFlipHorizontal}"
                            Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Canvas>
                </Viewbox>
            </Button>
            <Button Width="32" Height="32" Padding="0" ToolTipService.ToolTip="Flip Vertical"
                Background="Transparent" BorderThickness="0" Click="FlipVertical_Click">
                <Viewbox Width="18" Height="18">
                    <Canvas Width="24" Height="24">
                        <Path Data="{StaticResource IconPathFlipVertical}"
                            Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Canvas>
                </Viewbox>
            </Button>

            <Rectangle Width="1" Height="24"
                Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                VerticalAlignment="Center" Margin="8,0" />

        </StackPanel>
    </local:BoardItemBase.ItemSpecificToolbarContent>

</local:BoardItemBase>
