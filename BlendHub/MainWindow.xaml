<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlendHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BlendHub">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <!-- NavigationViewItem: custom template to style SelectionIndicator pill directly and override WinUI presenter limits -->
            <Style TargetType="NavigationViewItem">
                <Setter Property="Height" Value="60" />
                <Setter Property="Width" Value="72" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="NavigationViewItem">
                            <!-- Inner layout container representing the perfect compact square -->
                            <Grid x:Name="PresenterRoot" Background="Transparent" CornerRadius="2"
                                Width="64"
                                Height="52"
                                Margin="4"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                                <!-- Visual State Manager connected natively to the item's state engine -->
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="IconTranslation"
                                                    Storyboard.TargetProperty="Y"
                                                    To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ItemText"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="BackgroundPlate.Background"
                                                    Value="Transparent" />
                                                <Setter Target="SelectionIndicator.Opacity"
                                                    Value="0.0" />
                                                <Setter Target="IconPresenter.Foreground"
                                                    Value="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        
                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="IconTranslation"
                                                    Storyboard.TargetProperty="Y"
                                                    To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ItemText"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="BackgroundPlate.Background"
                                                    Value="{ThemeResource ControlSolidFillColorDefaultBrush}" />
                                                <Setter Target="SelectionIndicator.Opacity"
                                                    Value="0.0" />
                                                <Setter Target="IconPresenter.Foreground"
                                                    Value="{ThemeResource ControlStrongFillColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="IconTranslation"
                                                    Storyboard.TargetProperty="Y"
                                                    To="0" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ItemText"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="BackgroundPlate.Background"
                                                    Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                                <Setter Target="SelectionIndicator.Opacity"
                                                    Value="0.0" />
                                                <Setter Target="IconPresenter.Foreground"
                                                    Value="{ThemeResource ControlStrongFillColorDefaultBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        
                                        <VisualState x:Name="Disabled" />
                                        
                                        <VisualState x:Name="Selected">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="IconTranslation"
                                                    Storyboard.TargetProperty="Y"
                                                    To="8" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ItemText"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="BackgroundPlate.Background"
                                                    Value="{ThemeResource ControlSolidFillColorDefaultBrush}" />
                                                <Setter Target="SelectionIndicator.Opacity"
                                                    Value="1.0" />
                                                <Setter Target="IconPresenter.Foreground"
                                                    Value="{ThemeResource NavigationViewSelectionIndicatorForeground}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        
                                        <VisualState x:Name="SelectedUnfocused">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="IconTranslation"
                                                    Storyboard.TargetProperty="Y"
                                                    To="8" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ItemText"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="BackgroundPlate.Background"
                                                    Value="{ThemeResource ControlSolidFillColorDefaultBrush}" />
                                                <Setter Target="SelectionIndicator.Opacity"
                                                    Value="1.0" />
                                                <Setter Target="IconPresenter.Foreground"
                                                    Value="{ThemeResource NavigationViewSelectionIndicatorForeground}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        
                                        <VisualState x:Name="PointerOverSelected">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="IconTranslation"
                                                    Storyboard.TargetProperty="Y"
                                                    To="8" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ItemText"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="BackgroundPlate.Background"
                                                    Value="{ThemeResource ControlSolidFillColorDefaultBrush}" />
                                                <Setter Target="SelectionIndicator.Opacity"
                                                    Value="1.0" />
                                                <Setter Target="IconPresenter.Foreground"
                                                    Value="{ThemeResource NavigationViewSelectionIndicatorForeground}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        
                                        <VisualState x:Name="PressedSelected">
                                            <Storyboard>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="IconTranslation"
                                                    Storyboard.TargetProperty="Y"
                                                    To="8" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ItemText"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0.0" Duration="0:0:0.15" />
                                            </Storyboard>
                                            <VisualState.Setters>
                                                <Setter Target="BackgroundPlate.Background"
                                                    Value="{ThemeResource ControlSolidFillColorDefaultBrush}" />
                                                <Setter Target="SelectionIndicator.Opacity"
                                                    Value="1.0" />
                                                <Setter Target="IconPresenter.Foreground"
                                                    Value="{ThemeResource NavigationViewSelectionIndicatorForeground}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <!-- Native tactile rounded card highlight -->
                                <Border x:Name="BackgroundPlate" CornerRadius="4"
                                    Background="Transparent" />

                                <!-- Wrap SelectionIndicator in a grid so that its offset is 0,0 - this enables the offset animation. -->
                                <Grid Margin="2,0,0,0" HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                    <Rectangle x:Name="SelectionIndicator"
                                        Width="3"
                                        Height="20"
                                        Fill="{ThemeResource NavigationViewSelectionIndicatorForeground}"
                                        Opacity="0.0"
                                        RadiusX="2"
                                        RadiusY="2" />
                                </Grid>

                                <!-- Custom content layout with direct visual state targets -->
                                <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <ContentPresenter x:Name="IconPresenter"
                                        Grid.Row="0"
                                        Content="{TemplateBinding Icon}"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <ContentPresenter.RenderTransform>
                                            <TranslateTransform x:Name="IconTranslation" Y="0" />
                                        </ContentPresenter.RenderTransform>
                                    </ContentPresenter>

                                    <TextBlock x:Name="ItemText"
                                        Grid.Row="1"
                                        Text="{TemplateBinding Content}"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        FontSize="10"
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        TextAlignment="Center"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap"
                                        MaxWidth="56"
                                        ToolTipService.ToolTip="{TemplateBinding Content}"
                                        Opacity="1.0" />
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- WinUI 3 Gallery-style TitleBar -->
        <TitleBar
            x:Name="AppTitleBar"
            Title="BlendHub"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False"
            PaneToggleRequested="AppTitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/logo.png" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <Grid />
            </TitleBar.Content>
        </TitleBar>

        <!-- NavigationView matching WinUI 3 Gallery layout -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            Canvas.ZIndex="0"
            PaneDisplayMode="LeftCompact"
            IsBackButtonVisible="Collapsed"
            IsBackEnabled="False"
            AlwaysShowHeader="False"
            OpenPaneLength="72"
            CompactPaneLength="72"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            IsTabStop="False"
            IsPaneOpen="False"
            DisplayModeChanged="NavView_DisplayModeChanged"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeItem" Content="Home" Tag="home"
                                    AutomationProperties.AutomationId="HomeItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem x:Name="ProjectItem" Content="Projects" Tag="project"
                                    AutomationProperties.AutomationId="ProjectItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem x:Name="CanvasItem" Content="Canvas" Tag="canvas"
                                    AutomationProperties.AutomationId="CanvasItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />
                
                <NavigationViewItemHeader Content="Blender" />
                
                <NavigationViewItem x:Name="DownloadItem" Content="Download" Tag="download"
                                    AutomationProperties.AutomationId="DownloadItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="AddonsItem" Content="Addons" Tag="addons"
                                    AutomationProperties.AutomationId="AddonsItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="BackupItem" Content="Backup" Tag="backup"
                                    AutomationProperties.AutomationId="BackupItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem x:Name="RestoreItem" Content="Restore" Tag="restore"
                                    AutomationProperties.AutomationId="RestoreItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem x:Name="SyncItem" Content="Sync" Tag="sync"
                                    AutomationProperties.AutomationId="SyncItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="SettingsItem" Content="Settings" Tag="settings" 
                                    AutomationProperties.AutomationId="SettingsItem">
                    <NavigationViewItem.Icon>
                        <PathIcon Width="24" Height="24" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            
            <Frame x:Name="ContentFrameInternal"
                   Navigated="ContentFrame_Navigated" />
        </NavigationView>
    </Grid>
</Window>
