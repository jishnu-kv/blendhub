<Page
    x:Class="BlendHub.Pages.ProjectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:custom="using:BlendHub.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>

    <Grid x:Name="RootGrid"
          AllowDrop="True"
          DragOver="RootGrid_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- Fixed Header Section -->
        <StackPanel Grid.Row="0" Spacing="16" Padding="24,24,24,8">
            <!-- Header -->
            <Grid>
                <TextBlock Text="Projects" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />

                <Button x:Name="CreateProjectBtn" 
                        Content="Create Project" 
                        Click="ShowDialog_Click" 
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="24,10" 
                        FontSize="14" 
                        FontWeight="Normal"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Progress Bar -->
            <StackPanel x:Name="CreatingProgressPanel" Visibility="Collapsed" 
                        Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <ProgressBar Width="130" IsIndeterminate="True" ShowPaused="False" ShowError="False" />
                <TextBlock x:Name="ProgressText" Text="Creating project..." VerticalAlignment="Center" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Feedback -->
            <InfoBar x:Name="ProjectSuccessInfoBar"
                     IsOpen="False"
                     Severity="Success"
                     Title="Project Created">
                 <InfoBar.ActionButton>
                     <Button Content="Open Project" Click="OpenProject_Click" />
                 </InfoBar.ActionButton>
             </InfoBar>

            <!-- Projects List Header with Search and Sort -->
            <StackPanel x:Name="ProjectsListContainer" Spacing="8">
                <!-- Section Header with Search and Sort -->
                <Grid x:Name="ProjectsHeaderGrid" Visibility="Visible" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left side: Search and Refresh -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <AutoSuggestBox x:Name="SearchTextBox" 
                                       Width="280"
                                       VerticalAlignment="Center"
                                       PlaceholderText="Search projects..."
                                       TextChanged="Filter_TextChanged">
                            <AutoSuggestBox.QueryIcon>
                                <FontIcon Glyph="&#xE721;" FontSize="14" />
                            </AutoSuggestBox.QueryIcon>
                        </AutoSuggestBox>
                        
                        <Button x:Name="RefreshProjectsButton" 
                                Style="{StaticResource DefaultButtonStyle}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                Click="RefreshProjectsButton_Click"
                                ToolTipService.ToolTip="Refresh Projects"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                    </StackPanel>
                    
                    <!-- Right side: Sort Menu -->
                    <Button x:Name="SortButton"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            ToolTipService.ToolTip="Sort">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8CB;" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock x:Name="SortButtonText" Text="Date Created (Newest)" VerticalAlignment="Center" />
                            <FontIcon Glyph="&#xE70D;" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <RadioMenuFlyoutItem x:Name="SortFieldDateItem" 
                                                     Text="Date Created" 
                                                     GroupName="SortFieldGroup"
                                                     IsChecked="True"
                                                     Tag="Date"
                                                     Click="SortFieldItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="SortFieldModifiedItem" 
                                                     Text="Date Modified" 
                                                     GroupName="SortFieldGroup"
                                                     Tag="Modified"
                                                     Click="SortFieldItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="SortFieldNameItem" 
                                                     Text="Name" 
                                                     GroupName="SortFieldGroup"
                                                     Tag="Name"
                                                     Click="SortFieldItem_Click"/>
                                <MenuFlyoutSeparator/>
                                <RadioMenuFlyoutItem x:Name="SortOrderAscItem" 
                                                     Text="Ascending" 
                                                     GroupName="SortOrderGroup"
                                                     Tag="Asc"
                                                     Click="SortOrderItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="SortOrderDescItem" 
                                                     Text="Descending" 
                                                     GroupName="SortOrderGroup"
                                                     IsChecked="True"
                                                     Tag="Desc"
                                                     Click="SortOrderItem_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Scrollable Content Section -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
            <StackPanel Spacing="16">

                <!-- Drag and Drop Zone (Visible only when no projects exist) -->
                <Border x:Name="DropZone"
                        AllowDrop="True"
                        DragOver="DropZone_DragOver"
                        Drop="DropZone_Drop"
                        CornerRadius="8"
                        Padding="0"
                        MinHeight="180">
                    <Grid>
                        <Rectangle Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                   StrokeThickness="1.5"
                                   StrokeDashArray="2,2"
                                   RadiusX="8"
                                   RadiusY="8"
                                   Fill="Transparent"
                                   Margin="0"/>
                        
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" Padding="40,0">
                            <FontIcon Glyph="&#xE8E5;" FontSize="32" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Drag and drop to add project"
                                           HorizontalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="Drop a folder containing .blend files here"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:Name="BrowseProjectBtn"
                                    Click="BrowseProjectBtn_Click"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    Padding="16,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xED25;" FontSize="14"/>
                                    <TextBlock Text="Browse for project folder" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Projects List -->
                <ListView x:Name="ProjectsList"
                          SelectionMode="None"
                          HorizontalAlignment="Stretch">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Vertical" CacheLength="2" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Project">
                            <custom:ProjectCardView Project="{x:Bind}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- No Search Results Message -->
                <StackPanel x:Name="NoSearchResultsPanel" Spacing="16" Margin="0,40,0,0" HorizontalAlignment="Center" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE94C;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No projects found matching your search." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Full-Page Drag Overlay -->
        <Grid x:Name="DragOverlay"
              Grid.RowSpan="2"
              Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
              Visibility="Collapsed"
              Canvas.ZIndex="100"
              AllowDrop="True"
              DragOver="DragOverlay_DragOver"
              DragLeave="DragOverlay_DragLeave"
              Drop="DragOverlay_Drop">
            <Grid Margin="24">
                <Rectangle Stroke="{ThemeResource AccentFillColorDefaultBrush}"
                           StrokeThickness="2"
                           StrokeDashArray="3,3"
                           RadiusX="8"
                           RadiusY="8"
                           Fill="Transparent"
                           Margin="0"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <FontIcon Glyph="&#xE8E5;" FontSize="48" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                    <TextBlock Text="Drop folder to add project to BlendHub"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
