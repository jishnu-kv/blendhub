<UserControl
    x:Class="BlendHub.Controls.ProjectCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Controls"
    xmlns:models="using:BlendHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <toolkit:SettingsCard Margin="0,0,0,6"
                           Opacity="{x:Bind models:Project.GetOpacity(Project.FolderExists)}"
                           IsActionIconVisible="False"
                           IsClickEnabled="True"
                           Click="Card_Click"
                           CornerRadius="4">
        <toolkit:SettingsCard.Header>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Thumbnail -->
                <Border Grid.Column="0"
                        Grid.RowSpan="2"
                        CornerRadius="8"
                        Width="48"
                        Height="48"
                        VerticalAlignment="Center"
                        Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                    <Image x:Name="ThumbnailImage"
                           Loaded="Thumbnail_Loaded"
                           Stretch="Uniform" />
                </Border>

                <!-- Project Name & Error Badge -->
                <StackPanel Grid.Column="1"
                            Grid.Row="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Project.Name, Mode=OneWay}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind Project.StatusText, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                               FontWeight="Normal"
                               VerticalAlignment="Center"
                               Visibility="{x:Bind models:Project.GetMissingVisibility(Project.FolderExists), Mode=OneWay}" />
                </StackPanel>

                <!-- Project Info Grid -->
                <Grid Grid.Column="1"
                      Grid.Row="1"
                      ColumnSpacing="16"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{x:Bind Project.Path, Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="4"
                                VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE925;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind Project.BlenderVersion, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="{x:Bind models:Project.FormatDate(Project.CreatedAt), Mode=OneWay}"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </toolkit:SettingsCard.Header>

        <!-- Action Buttons -->
        <local:BlenderLaunchButton Project="{x:Bind Project, Mode=OneWay}"
                                     Text="Open Project"
                                     IconGlyph="&#xE8DA;"
                                     ShowManageOptions="True"
                                     RequestRefresh="RequestRefresh" />
    </toolkit:SettingsCard>
</UserControl>
