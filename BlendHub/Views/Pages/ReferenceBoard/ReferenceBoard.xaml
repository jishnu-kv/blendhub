<Page
    x:Class="BlendHub.ReferenceBoard.ReferenceBoard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.ReferenceBoard"
    xmlns:controls="using:BlendHub.ReferenceBoard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:community="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ReferenceBoardStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:ZoomFactorConverter x:Key="ZoomFactorConverter" />
            <local:BoolToDoubleConverter x:Key="BoolToDoubleConverter" />

            <Storyboard x:Name="SaveSuccessAnimation">
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SaveIcon"
                    Storyboard.TargetProperty="Opacity">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1" />
                    <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0" />
                    <EasingDoubleKeyFrame KeyTime="0:0:1.6" Value="0" />
                    <EasingDoubleKeyFrame KeyTime="0:0:1.8" Value="1" />
                </DoubleAnimationUsingKeyFrames>
                <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CheckIcon"
                    Storyboard.TargetProperty="Opacity">
                    <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0" />
                    <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="0" />
                    <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1" />
                    <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="1" />
                    <EasingDoubleKeyFrame KeyTime="0:0:1.7" Value="0" />
                </DoubleAnimationUsingKeyFrames>
            </Storyboard>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="MainRoot" KeyDown="Page_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title Bar -->
            <RowDefinition Height="*" />    <!-- Main Content -->
            <RowDefinition Height="Auto" /> <!-- Bottom Status Bar -->
        </Grid.RowDefinitions>

        <!-- Unified Header & Toolbar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="24,12,12,12" ColumnSpacing="12"
            Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Title Area -->
                <ColumnDefinition Width="*" />    <!-- Center Tools Area -->
                <ColumnDefinition Width="Auto" /> <!-- Board Actions Area -->
            </Grid.ColumnDefinitions>

            <!-- 1. Title Area -->
            <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="Reference Board" FontSize="24" FontWeight="SemiBold" />
            </StackPanel>

            <!-- 2. Center: Canvas Tools -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                Orientation="Horizontal" Spacing="12">
                <community:Segmented x:Name="MainToolSegmented"
                    SelectionChanged="MainToolSegmented_SelectionChanged"
                    SelectedIndex="0" VerticalAlignment="Center" MinHeight="32">
                    <community:SegmentedItem Tag="Select" ToolTipService.ToolTip="Select Tool"
                        MinWidth="40" MinHeight="32" Padding="0">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconPathCursor}"
                                Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                        </Viewbox>
                    </community:SegmentedItem>
                    <community:SegmentedItem Tag="Shape" ToolTipService.ToolTip="Drawing Tools"
                        MinWidth="40" MinHeight="32" Padding="0">
                        <FontIcon Glyph="&#xEE56;" FontSize="14" VerticalAlignment="Center" />
                    </community:SegmentedItem>
                </community:Segmented>
            </StackPanel>

            <!-- 3. Right: Board Management -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                VerticalAlignment="Center">
                <Button x:Name="NewBoardButton" Click="ClearBoard_Click" Height="32" Padding="12,0"
                    Style="{StaticResource SubtleButtonStyle}" ToolTipService.ToolTip="New Board">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="16"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="New" />
                    </StackPanel>
                </Button>

                <SplitButton x:Name="AddImageButton" Click="AddImageSplitButton_Click" Height="32"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="Import Content">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEB9F;" FontSize="16" />
                        <TextBlock Text="Import" />
                    </StackPanel>
                    <SplitButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Import from Folder" Click="AddImageButton_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xED25;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Import from Clipboard"
                                Click="ImportFromClipboard_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE77F;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Add Text" Click="AddTextButton_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8D2;" />
                                </MenuFlyoutItem.Icon>
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="T" Modifiers="Control" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>

                <AppBarSeparator Margin="4,4" />

                <ComboBox x:Name="ProjectsComboBox" Width="140" Height="32"
                    PlaceholderText="Select Board"
                    SelectionChanged="ProjectsComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8F1;" FontSize="14" />
                                <TextBlock Text="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button x:Name="SaveButton" Click="SaveButton_Click" Height="32" Width="32"
                    Padding="0" Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="Save Board">
                    <Grid>
                        <FontIcon x:Name="SaveIcon" Glyph="&#xE74E;" FontSize="16" Opacity="1" />
                        <SymbolIcon x:Name="CheckIcon" Symbol="Accept" Opacity="0"
                            RenderTransformOrigin="0.5,0.5">
                            <SymbolIcon.RenderTransform>
                                <ScaleTransform x:Name="CheckMarkScale" ScaleX="0.5" ScaleY="0.5" />
                            </SymbolIcon.RenderTransform>
                        </SymbolIcon>
                    </Grid>
                </Button>

                <Button x:Name="BoardActionsButton" Background="Transparent" BorderThickness="0"
                    Height="32" Padding="8,0" ToolTipService.ToolTip="Board Actions">
                    <FontIcon Glyph="&#xE712;" FontSize="16" />
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Clear Board" Click="ClearBoard_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE894;" />
                                </MenuFlyoutItem.Icon>
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="C" Modifiers="Control,Shift" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Delete Board" Click="DeleteBoard_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="D" Modifiers="Control,Shift" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Shortcuts" Click="ShowShortcuts_Click">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xEDA7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content (Canvas Area) -->
        <Grid Grid.Row="1" x:Name="MainAreaGrid">
            <!-- Canvas Area -->
            <Grid x:Name="CanvasContainer" Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}" Loaded="CanvasContainer_Loaded"
                  SizeChanged="CanvasContainer_SizeChanged">
                <Canvas x:Name="InfiniteCanvasArea" HorizontalAlignment="Left" VerticalAlignment="Top"
                        AllowDrop="True" DragOver="Canvas_DragOver" Drop="Canvas_Drop"
                        PointerMoved="Canvas_PointerMoved" PointerReleased="Canvas_PointerReleased">
                    <Canvas.RenderTransform>
                        <CompositeTransform x:Name="CanvasTransform" ScaleX="1" ScaleY="1" TranslateX="0" TranslateY="0" />
                    </Canvas.RenderTransform>
                </Canvas>
            </Grid>
        </Grid>

        <!-- Fixed Bottom Status Bar -->
        <Border Grid.Row="2" Height="44" Background="Transparent"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid Padding="4,0">
                <!-- Center: Item Info (visible when item selected) -->
                <StackPanel x:Name="ItemInfoPanel" HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed">
                    <TextBlock x:Name="ItemSizeText" Text="0 x 0 px" FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Left: Item Properties & Creation Tools -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Default: Cursor Info (visible when no tool/item selected) -->
                    <StackPanel x:Name="CursorInfoPanel" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="8" Padding="6,0">
                        <Viewbox Width="14" Height="14">
                            <Path Data="{StaticResource IconPathCursor}"
                                Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Viewbox>
                        <TextBlock
                            x:Name="CursorPosText"
                            Text="0, 0 px"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontFamily="Consolas"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <!-- Shape Creation Tools -->
                    <StackPanel x:Name="ShapeCreationTools" Orientation="Horizontal" Spacing="6"
                        Padding="2,0" Visibility="Collapsed">
                        <community:Segmented x:Name="ShapeSegmented"
                            SelectionChanged="ShapeSegmented_SelectionChanged"
                            SelectedIndex="0" VerticalAlignment="Center" MinHeight="32">
                            <community:SegmentedItem Tag="Pen" ToolTipService.ToolTip="Pen"
                                MinWidth="40" MinHeight="32" Padding="0">
                                <FontIcon Glyph="&#xE76D;" FontSize="14" VerticalAlignment="Center" />
                            </community:SegmentedItem>
                            <community:SegmentedItem Tag="Rectangle"
                                ToolTipService.ToolTip="Rectangle" MinWidth="40" MinHeight="32"
                                Padding="0">
                                <FontIcon Glyph="&#xE739;" FontSize="14" VerticalAlignment="Center" />
                            </community:SegmentedItem>
                            <community:SegmentedItem Tag="Circle" ToolTipService.ToolTip="Circle"
                                MinWidth="40" MinHeight="32" Padding="0">
                                <FontIcon Glyph="&#xEA3A;" FontSize="14" VerticalAlignment="Center" />
                            </community:SegmentedItem>
                            <community:SegmentedItem Tag="Line" ToolTipService.ToolTip="Line"
                                MinWidth="40" MinHeight="32" Padding="0">
                                <FontIcon Glyph="&#xE738;" FontSize="14" VerticalAlignment="Center" />
                            </community:SegmentedItem>
                            <community:SegmentedItem Tag="Arrow" ToolTipService.ToolTip="Arrow"
                                MinWidth="40" MinHeight="32" Padding="0">
                                <FontIcon Glyph="&#xE742;" FontSize="14" VerticalAlignment="Center" />
                            </community:SegmentedItem>
                        </community:Segmented>
                        <Rectangle Width="1" Height="24"
                            Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                            VerticalAlignment="Center" Margin="8,0" />
                    </StackPanel>

                    <!-- Shape Appearance Controls -->
                    <StackPanel x:Name="ShapeAppearanceControls" Orientation="Horizontal"
                        Spacing="4" Visibility="Collapsed">
                        <DropDownButton x:Name="FillDropdown" Height="32" Padding="8,0"
                            Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="ShapeFillPreview" Glyph="&#xF137;" FontSize="18"
                                    VerticalAlignment="Center" Margin="0,-1,0,0"
                                    Foreground="Transparent" Visibility="Collapsed" />
                                <FontIcon x:Name="ShapeFillNoneIcon" Glyph="&#xF140;" FontSize="18"
                                    VerticalAlignment="Center" Margin="0,-1,0,0" />
                                <TextBlock Text="Fill" VerticalAlignment="Center" />
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <Flyout Placement="Top">
                                    <StackPanel Width="280" Spacing="12">
                                        <GridView x:Name="ShapeFillColorPicker"
                                            SelectionMode="Single"
                                            SelectionChanged="ShapeFillColorPicker_SelectionChanged"
                                            ItemContainerStyle="{StaticResource ShapeColorPaletteItemStyle}"
                                            Padding="0">
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal"
                                                        MaximumRowsOrColumns="6" ItemWidth="46"
                                                        ItemHeight="46" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                        </GridView>
                                        <controls:AlphaSlider x:Name="ShapeOpacitySlider"
                                            Alpha="100" Header="Opacity"
                                            ValueChanged="ShapeSlider_ValueChanged" />
                                    </StackPanel>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>

                        <DropDownButton x:Name="OutlineDropdown" Height="32" Padding="8,0"
                            Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="ShapeOutlinePreview" Glyph="&#xF138;"
                                    FontSize="18" VerticalAlignment="Center" Margin="0,-1,0,0" />
                                <FontIcon x:Name="ShapeOutlineNoneIcon" Glyph="&#xF140;"
                                    FontSize="18" VerticalAlignment="Center" Margin="0,-1,0,0"
                                    Visibility="Collapsed" />
                                <TextBlock Text="Outline" VerticalAlignment="Center" />
                            </StackPanel>
                            <DropDownButton.Flyout>
                                <Flyout Placement="Top">
                                    <StackPanel Width="280" Spacing="12">
                                        <GridView x:Name="ShapeOutlineColorPicker"
                                            SelectionMode="Single"
                                            SelectionChanged="ShapeOutlineColorPicker_SelectionChanged"
                                            ItemContainerStyle="{StaticResource ShapeColorPaletteItemStyle}"
                                            Padding="0">
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal"
                                                        MaximumRowsOrColumns="6" ItemWidth="46"
                                                        ItemHeight="46" />
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                        </GridView>
                                        <controls:AlphaSlider x:Name="ShapeOutlineOpacitySlider"
                                            Alpha="100" Header="Opacity"
                                            ValueChanged="ShapeSlider_ValueChanged" />
                                        <TextBlock Text="Thickness" FontWeight="SemiBold"
                                            Margin="0,8,0,0" />
                                        <Grid Height="80" Background="Transparent" Margin="0,4">
                                            <Path x:Name="ShapeThicknessPreview"
                                                Data="M 0,30 C 35,0 85,60 110,30 S 185,0 220,30"
                                                Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                                StrokeThickness="3"
                                                StrokeStartLineCap="Round"
                                                StrokeEndLineCap="Round"
                                                Stretch="Uniform"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="20,0" />
                                        </Grid>
                                        <Slider x:Name="ShapeThicknessSlider" Minimum="1"
                                            Maximum="20" Value="2"
                                            ValueChanged="ShapeSlider_ValueChanged" />
                                    </StackPanel>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                    </StackPanel>

                    <!-- Common Management Tools -->
                    <StackPanel x:Name="ItemManagementTools" Orientation="Horizontal" Spacing="4"
                        Visibility="Collapsed">
                        <ContentControl x:Name="TextItemToolbarContent" VerticalAlignment="Center" />
                        <ContentControl x:Name="ImageItemToolbarContent" VerticalAlignment="Center" />

                        <Button x:Name="ForwardButton" Click="CommonButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTipService.ToolTip="Bring Forward">
                            <Viewbox Width="18" Height="18">
                                <Path Data="{StaticResource IconPathPositionToFront}"
                                    Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="BackwardButton" Click="CommonButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTipService.ToolTip="Send Backward">
                            <Viewbox Width="18" Height="18">
                                <Path Data="{StaticResource IconPathPositionToBack}"
                                    Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Viewbox>
                        </Button>

                        <Rectangle Width="1" Height="24"
                            Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                            VerticalAlignment="Center" Margin="8,0" />

                        <ToggleButton x:Name="ItemLockButton" Click="CommonButton_Click"
                            Style="{StaticResource ToolbarToggleButtonStyle}"
                            ToolTipService.ToolTip="Lock/Unlock">
                            <FontIcon x:Name="ItemLockIcon" Glyph="&#xE72E;" FontSize="14" />
                        </ToggleButton>
                        <Button x:Name="ItemDeleteButton" Click="CommonButton_Click"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTipService.ToolTip="Delete">
                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="IndianRed" />
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Zoom Controls -->
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8"
                    Padding="2,0" VerticalAlignment="Center">
                    <Button x:Name="ZoomFitButton" Click="ZoomFit_Click" Height="32" Padding="8,0"
                        Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE9A6;" FontSize="14" />
                    </Button>
                    <ComboBox x:Name="ZoomComboBox" IsEditable="True" Width="85" Height="32"
                        SelectionChanged="ZoomComboBox_SelectionChanged"
                        TextSubmitted="ZoomComboBox_TextSubmitted">
                        <x:String>1000%</x:String>
                        <x:String>900%</x:String>
                        <x:String>800%</x:String>
                        <x:String>700%</x:String>
                        <x:String>600%</x:String>
                        <x:String>500%</x:String>
                        <x:String>400%</x:String>
                        <x:String>300%</x:String>
                        <x:String>200%</x:String>
                        <x:String>100%</x:String>
                        <x:String>75%</x:String>
                        <x:String>50%</x:String>
                        <x:String>25%</x:String>
                        <x:String>10%</x:String>
                    </ComboBox>
                    <Button x:Name="ZoomOutButton" Click="ZoomOut_Click" Height="32" Width="32"
                        Padding="0" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE71F;" FontSize="14" />
                    </Button>
                    <Slider x:Name="ZoomSlider" Width="120" Minimum="0.01" Maximum="10.0"
                        StepFrequency="0.01" ValueChanged="ZoomSlider_ValueChanged"
                        VerticalAlignment="Center"
                        ThumbToolTipValueConverter="{StaticResource ZoomFactorConverter}" />
                    <Button x:Name="ZoomInButton" Click="ZoomIn_Click" Height="32" Width="32"
                        Padding="0" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE8A3;" FontSize="14" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
