<Page
    x:Class="BlendHub.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:BlendHub.Models"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.Controls.SettingsControls/SettingsExpander/SettingsExpander.xaml" />
                <ResourceDictionary Source="ms-appx:///CommunityToolkit.WinUI.Controls.SettingsControls/SettingsCard/SettingsCard.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <x:Double x:Key="SettingsCardSpacing">4</x:Double>

            <Style x:Key="SettingsSectionHeaderTextBlockStyle"
                   BasedOn="{StaticResource BodyStrongTextBlockStyle}"
                   TargetType="TextBlock">
                <Style.Setters>
                    <Setter Property="Margin" Value="1,16,0,6" />
                </Style.Setters>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <Grid x:Name="HeaderGrid" Margin="36,36,36,0" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="PageHeader"
                       Text="Settings"
                       Style="{StaticResource TitleTextBlockStyle}"
                       AutomationProperties.HeadingLevel="Level1" />
            <TextBlock Grid.Row="1"
                       Text="Configure default directories, launchers, and themes."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </Grid>
            
        <ScrollView
            Grid.Row="1"
            Padding="36,8,36,0"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <Border>
                <StackPanel Spacing="{StaticResource SettingsCardSpacing}">

                <!-- Appearance & Personalization Section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Appearance &amp; personalization" />

                <controls:SettingsCard Description="Choose which theme you want the app to use."
                                       Header="App Theme"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE790;}">
                    <ComboBox x:Name="ThemeComboBox" Width="200" VerticalAlignment="Center" SelectionChanged="ThemeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Auto" Tag="Default" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                </controls:SettingsCard>

                <controls:SettingsCard Description="Choose which page should open when you start BlendHub."
                                       Header="Default Page"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE71D;}">
                    <ComboBox x:Name="DefaultPageComboBox" Width="200" VerticalAlignment="Center" SelectionChanged="DefaultPageComboBox_SelectionChanged">
                        <ComboBoxItem Content="Home" Tag="home" />
                        <ComboBoxItem Content="Download" Tag="download" />
                        <ComboBoxItem Content="Backup" Tag="backup" />
                        <ComboBoxItem Content="Restore" Tag="restore" />
                        <ComboBoxItem Content="Sync" Tag="sync" />
                        <ComboBoxItem Content="Projects" Tag="project" />
                    </ComboBox>
                </controls:SettingsCard>

                <!-- Project Preferences Section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Project preferences" />

                <controls:SettingsCard Description="Automatically detect the Blender version used in projects on startup."
                                       Header="Auto-Detect Project Version"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE9F5;}">
                    <ToggleSwitch x:Name="AutoDetectVersionToggle" VerticalAlignment="Center" Toggled="AutoDetectVersionToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard Description="Automatically expand project details by default."
                                       Header="Expand Projects by Default"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE8F4;}">
                    <ToggleSwitch x:Name="ExpandFoldersToggle" VerticalAlignment="Center" Toggled="ExpandFoldersToggle_Toggled" />
                </controls:SettingsCard>

                <controls:SettingsCard Description="Only show .blend files from the root and immediate subfolders, ignoring deeper nested files."
                                       Header="Filter Nested Blend Files"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xE71C;}">
                    <ToggleSwitch x:Name="FilterNestedBlendFilesToggle" VerticalAlignment="Center" Toggled="FilterNestedBlendFilesToggle_Toggled" />
                </controls:SettingsCard>

                <!-- Default Project Folders Configuration -->
                <controls:SettingsExpander Header="Default Project Folder Structure"
                                         Description="Configure the default folders created for new projects."
                                         HeaderIcon="{ui:FontIcon Glyph=&#xF168;}"
                                         IsExpanded="False"
                                         ItemsSource="{x:Bind DefaultFolders}">
                    <controls:SettingsExpander.ItemTemplate>
                        <DataTemplate x:DataType="models:ProjectFolder">
                            <controls:SettingsCard CornerRadius="0" Margin="0,-1,0,0"
                                                   AllowDrop="True"
                                                   DragOver="SettingsCard_DragOver"
                                                   Drop="SettingsCard_Drop"
                                                   DataContext="{x:Bind}">
                                <controls:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Grid CanDrag="True"
                                              DragStarting="Grip_DragStarting"
                                              Background="Transparent"
                                              VerticalAlignment="Center"
                                              Padding="0,0,4,0"
                                              DataContext="{x:Bind}"
                                              ToolTipService.ToolTip="Drag to reorder folder">
                                            <Path Data="M16 17C17.1046 17 18 17.8954 18 19C18 20.1046 17.1046 21 16 21C14.8954 21 14 20.1046 14 19C14 17.8954 14.8954 17 16 17ZM8 17C9.10457 17 10 17.8954 10 19C10 20.1046 9.10457 21 8 21C6.89543 21 6 20.1046 6 19C6 17.8954 6.89543 17 8 17ZM16 10C17.1046 10 18 10.8954 18 12C18 13.1046 17.1046 14 16 14C14.8954 14 14 13.1046 14 12C14 10.8954 14.8954 10 16 10ZM8 10C9.10457 10 10 10.8954 10 12C10 13.1046 9.10457 14 8 14C6.89543 14 6 13.1046 6 12C6 10.8954 6.89543 10 8 10ZM16 3C17.1046 3 18 3.89543 18 5C18 6.10457 17.1046 7 16 7C14.8954 7 14 6.10457 14 5C14 3.89543 14.8954 3 16 3ZM8 3C9.10457 3 10 3.89543 10 5C10 6.10457 9.10457 7 8 7C6.89543 7 6 6.10457 6 5C6 3.89543 6.89543 3 8 3Z" 
                                                  Fill="{ThemeResource TextFillColorSecondaryBrush}"
                                                  Width="14" Height="14"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center" />
                                        </Grid>
                                        <TextBlock Text="{x:Bind Label, Mode=OneWay}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </controls:SettingsCard.Header>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBox Grid.Column="0" 
                                             Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             PlaceholderText="Folder name" 
                                             VerticalAlignment="Center" Width="200"
                                             KeyDown="FolderNameTextBox_KeyDown"
                                             LostFocus="FolderNameTextBox_LostFocus" />
                                    <Button Grid.Column="1" 
                                            Click="RemoveFolder_Click" 
                                            Content="&#xE711;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Stretch"
                                            DataContext="{x:Bind}"
                                            IsTabStop="False" />
                                </Grid>
                            </controls:SettingsCard>
                        </DataTemplate>
                    </controls:SettingsExpander.ItemTemplate>
                    <controls:SettingsExpander.ItemsFooter>
                        <controls:SettingsCard IsClickEnabled="True" Click="AddFolder_Click" CornerRadius="0,0,4,4" Margin="0,-1,0,0" Style="{StaticResource DefaultSettingsExpanderItemStyle}">
                            <controls:SettingsCard.Header>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                                    <TextBlock Text="Add Folder" VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard.Header>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.ItemsFooter>
                </controls:SettingsExpander>

                <!-- File Type Associations (Launchers) -->
                <controls:SettingsExpander Header="Default File Launchers"
                                         Description="Set default programs for file types. New projects will automatically use these associations."
                                         HeaderIcon="{ui:FontIcon Glyph=&#xE7AC;}"
                                         IsExpanded="False"
                                         ItemsSource="{x:Bind Launchers}">
                    <controls:SettingsExpander.ItemTemplate>
                        <DataTemplate x:DataType="models:FileLauncher">
                            <controls:SettingsCard CornerRadius="0" Margin="0,-1,0,0">
                                <controls:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="File type" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                        <TextBox Text="{x:Bind Extension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 PlaceholderText=".psd" 
                                                 VerticalAlignment="Center" Width="80"
                                                 KeyDown="ExtensionTextBox_KeyDown"
                                                 LostFocus="ExtensionTextBox_LostFocus" />
                                    </StackPanel>
                                </controls:SettingsCard.Header>
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                    <TextBlock Grid.Column="0" Text="Program path:" VerticalAlignment="Center" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Visibility="{x:Bind ProgramPath, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}" />
                                    <TextBlock Grid.Column="1"
                                             Text="{x:Bind ProgramPath, Mode=OneWay}" 
                                             TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center"
                                             Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                             HorizontalAlignment="Stretch" />
                                    <Button Grid.Column="2" 
                                            Click="BrowseLauncherProgram_Click" 
                                            Content="&#xE8DA;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            ToolTipService.ToolTip="Browse Program"
                                            VerticalAlignment="Stretch" />
                                    <Button Grid.Column="3" 
                                            Click="RemoveLauncher_Click" 
                                            Content="&#xE711;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Stretch"
                                            DataContext="{x:Bind}"
                                            IsTabStop="False" />
                                </Grid>
                            </controls:SettingsCard>
                        </DataTemplate>
                    </controls:SettingsExpander.ItemTemplate>
                    <controls:SettingsExpander.ItemsFooter>
                        <controls:SettingsCard IsClickEnabled="True" Click="AddLauncher_Click" CornerRadius="0,0,4,4" Margin="0,-1,0,0" Style="{StaticResource DefaultSettingsExpanderItemStyle}">
                            <controls:SettingsCard.Header>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                                    <TextBlock Text="Add File Launcher" VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard.Header>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.ItemsFooter>
                </controls:SettingsExpander>

                <!-- Blender & Backups Section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" Text="Blender &amp; backups" />
                
                <!-- Custom Blender Installations -->
                <controls:SettingsExpander Header="Custom Blender Installations"
                                         Description="Add custom Blender executables to show on the Home page."
                                         HeaderIcon="{ui:FontIcon Glyph=&#xE7B8;}"
                                         IsExpanded="False"
                                         ItemsSource="{x:Bind CustomBlenders}">
                    <controls:SettingsExpander.ItemTemplate>
                        <DataTemplate x:DataType="models:CustomBlenderInfo">
                            <controls:SettingsCard CornerRadius="0" Margin="0,-1,0,0">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                    <TextBlock Grid.Column="0" 
                                             Text="{x:Bind Path, Mode=OneWay}" 
                                             TextTrimming="CharacterEllipsis"
                                             VerticalAlignment="Center" />
                                    <Button Grid.Column="1" 
                                            Click="BrowseCustomBlender_Click" 
                                            Content="&#xE8DA;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            ToolTipService.ToolTip="Change Path"
                                            VerticalAlignment="Stretch"
                                            DataContext="{x:Bind}" />
                                    <Button Grid.Column="2" 
                                            Click="RemoveCustomBlender_Click" 
                                            Content="&#xE711;" 
                                            FontFamily="Segoe Fluent Icons" 
                                            Style="{StaticResource SubtleButtonStyle}"
                                            VerticalAlignment="Stretch"
                                            DataContext="{x:Bind}"
                                            IsTabStop="False" />
                                </Grid>
                            </controls:SettingsCard>
                        </DataTemplate>
                    </controls:SettingsExpander.ItemTemplate>
                    <controls:SettingsExpander.ItemsFooter>
                        <controls:SettingsCard IsClickEnabled="True" Click="AddCustomBlender_Click" CornerRadius="0,0,4,4" Margin="0,-1,0,0" Style="{StaticResource DefaultSettingsExpanderItemStyle}">
                            <controls:SettingsCard.Header>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                                    <TextBlock Text="Add Blender Executable" VerticalAlignment="Center" />
                                </StackPanel>
                            </controls:SettingsCard.Header>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.ItemsFooter>
                </controls:SettingsExpander>

                <!-- Backup and Restore Settings -->
                <controls:SettingsCard Description="The location where your Blender backup files will be saved and restored from."
                                       Header="Backup Location"
                                       HeaderIcon="{ui:FontIcon Glyph=&#xEC50;}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBlock x:Name="BackupLocationTextBox" 
                                 Grid.Column="0"
                                 VerticalAlignment="Center" 
                                 Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                 TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1"
                                Click="BrowseBackupLocation_Click" 
                                Content="&#xE8DA;" 
                                FontFamily="Segoe Fluent Icons" 
                                ToolTipService.ToolTip="Browse Folder"
                                VerticalAlignment="Stretch" />
                    </Grid>
                </controls:SettingsCard>

                <!-- About & Legal Section -->
                <TextBlock Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"
                           Text="About" />

                <controls:SettingsCard Description="Version 1.0.0"
                                       Header="BlendHub"
                                       HeaderIcon="{ui:BitmapIcon Source=ms-appx:///Assets/logo.png}"
                                       Margin="0,0,0,24">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <HyperlinkButton NavigateUri="https://github.com/DesignLipsx/BlendHub" Padding="10,6" FontSize="13" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="GitHub Repository" VerticalAlignment="Center" />
                                </StackPanel>
                            </HyperlinkButton>
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsCard>
                </StackPanel>
            </Border>
        </ScrollView>
    </Grid>
</Page>
