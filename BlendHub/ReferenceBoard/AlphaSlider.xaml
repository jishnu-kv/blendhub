<UserControl
    x:Class="BlendHub.ReferenceBoard.AlphaSlider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="12"
    d:DesignWidth="300">

    <UserControl.Resources>
        <!-- Minimal Slider Style for AlphaSlider -->
        <Style x:Key="MinimalSliderStyle" TargetType="Slider">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Grid x:Name="HorizontalTemplate" Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Rectangle x:Name="HorizontalTrackRect" Grid.Row="1"
                                    Grid.ColumnSpan="3" Fill="Transparent" Height="12" />
                                <Rectangle x:Name="HorizontalDecreaseRect" Grid.Row="1"
                                    Fill="Transparent" />

                                <Thumb x:Name="HorizontalThumb"
                                    Grid.Row="0"
                                    Grid.RowSpan="3"
                                    Grid.Column="1"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    AutomationProperties.AccessibilityView="Raw"
                                    DataContext="{TemplateBinding Value}"
                                    Height="24"
                                    Width="24"
                                    FocusVisualMargin="-2">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid x:Name="RootGrid" Background="Transparent">
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal">
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="InnerThumbScaleTransform"
                                                                    Storyboard.TargetProperty="ScaleX"
                                                                    To="1.0" Duration="0:0:0.1" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="InnerThumbScaleTransform"
                                                                    Storyboard.TargetProperty="ScaleY"
                                                                    To="1.0" Duration="0:0:0.1" />
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="PointerOver">
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="InnerThumbScaleTransform"
                                                                    Storyboard.TargetProperty="ScaleX"
                                                                    To="1.2" Duration="0:0:0.1" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="InnerThumbScaleTransform"
                                                                    Storyboard.TargetProperty="ScaleY"
                                                                    To="1.2" Duration="0:0:0.1" />
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Pressed">
                                                            <Storyboard>
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="InnerThumbScaleTransform"
                                                                    Storyboard.TargetProperty="ScaleX"
                                                                    To="0.8" Duration="0:0:0.1" />
                                                                <DoubleAnimation
                                                                    Storyboard.TargetName="InnerThumbScaleTransform"
                                                                    Storyboard.TargetProperty="ScaleY"
                                                                    To="0.8" Duration="0:0:0.1" />
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Disabled" />
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>

                                                <!-- Outer Thumb Border -->
                                                <Border
                                                    BorderBrush="{ThemeResource SliderThumbBorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{ThemeResource SliderOuterThumbBackground}"
                                                    CornerRadius="12">
                                                    <!-- Inner Thumb (The central dot) -->
                                                    <Ellipse x:Name="SliderInnerThumb"
                                                        Fill="{TemplateBinding Background}"
                                                        Width="12"
                                                        Height="12"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        RenderTransformOrigin="0.5,0.5">
                                                        <Ellipse.RenderTransform>
                                                            <ScaleTransform
                                                                x:Name="InnerThumbScaleTransform" />
                                                        </Ellipse.RenderTransform>
                                                    </Ellipse>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="Transparent" CornerRadius="6" Margin="0,8">
        <StackPanel Spacing="4">
            <ContentPresenter Content="{x:Bind Header, Mode=OneWay}"
                ContentTemplate="{x:Bind HeaderTemplate, Mode=OneWay}"
                Margin="0,0,0,4" />
            <Grid x:Name="AlphaSliderGrid">

                <!-- Layer 1: Checkered Background -->
                <Rectangle x:Name="AlphaSliderCheckeredBackgroundRectangle"
                    Height="12"
                    VerticalAlignment="Center"
                    Margin="2,0"
                    RadiusX="6" RadiusY="6">
                    <Rectangle.Fill>
                        <ImageBrush x:Name="CheckerImageBrush" />
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Layer 2: Gradient Layer -->
                <Rectangle x:Name="AlphaSliderBackgroundRectangle"
                    Height="12"
                    VerticalAlignment="Center"
                    Margin="2,0"
                    RadiusX="6" RadiusY="6">
                    <Rectangle.Fill>
                        <LinearGradientBrush x:Name="AlphaSliderGradientBrush" StartPoint="0,0.2"
                            EndPoint="1,0.5">
                            <GradientStop x:Name="StartStop" Offset="0" Color="Transparent" />
                            <GradientStop x:Name="EndStop" Offset="1" Color="White" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Layer 3: Slider Control -->
                <Slider x:Name="InternalSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="{x:Bind Alpha, Mode=TwoWay}"
                    Padding="0"
                    Margin="0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Style="{StaticResource MinimalSliderStyle}">
                </Slider>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
