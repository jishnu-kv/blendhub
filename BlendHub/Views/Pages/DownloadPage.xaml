<Page
    x:Class="BlendHub.Pages.DownloadPage"
    x:Name="pageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="LatestBadgeForegroundBrush" Color="White" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="LatestBadgeForegroundBrush" Color="Black" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="LatestBadgeForegroundBrush" Color="Black" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <converters:BytesToSizeConverter x:Key="BytesToSizeConverter" />
            <local:DownloadGroupHeaderMarginConverter x:Key="DownloadGroupHeaderMarginConverter" />
            <CollectionViewSource x:Name="GroupedVersions" IsSourceGrouped="True" />

            <!-- GridView Item Template -->
            <DataTemplate x:Key="DownloadGridViewTemplate" x:DataType="models:BlenderVersionGroup">
                <Grid Height="130" Padding="16"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" CornerRadius="4"
                      RowDefinitions="Auto,*,Auto"
                      HorizontalAlignment="Stretch">
                    <Grid Grid.Row="0" Margin="0,0,0,4" ColumnDefinitions="Auto,*">
                        <ImageIcon Source="/Assets/blender_logo.png" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind DisplayVersion}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                    Visibility="{x:Bind LtsVisibility}"
                                    ToolTipService.ToolTip="{x:Bind LtsSupportPeriod}">
                                <TextBlock Text="LTS" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                    CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                    Visibility="{x:Bind IsLatest}">
                                <TextBlock Text="Latest" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource LatestBadgeForegroundBrush}" VerticalAlignment="Center"/>
                            </Border>
                            <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                    CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                    Visibility="{x:Bind UpdateAvailableVisibility, Mode=OneWay}">
                                <TextBlock Text="Update Available" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="{x:Bind LastUpdatedText}" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               MaxLines="3" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" Margin="0,4,0,4" />
                    <TextBlock Grid.Row="2" Text="{x:Bind InstallersCountText}" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                </Grid>
            </DataTemplate>
            <!-- Detail Installer Template -->
            <DataTemplate x:Key="DetailInstallerTemplate" x:DataType="models:WindowsInstaller">
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" VerticalAlignment="Center">
                        <!-- Filename and Metadata -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind Filename}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                <Run Text="{x:Bind SizeBytes, Converter={StaticResource BytesToSizeConverter}}"/>
                                <Run Text=" • "/>
                                <Run Text="{x:Bind ReleaseDate}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Action Button -->
                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <!-- Download button -->
                             <SplitButton Click="InstallerDownload_Click"
                                          DataContext="{x:Bind}"
                                          Height="36"
                                          Width="136"
                                          VerticalAlignment="Center"
                                          Visibility="{x:Bind local:DownloadPage.GetDownloadButtonVisibility(Filename), Mode=OneTime}">
                                 <SplitButton.Resources>
                                     <!-- Background -->
                                     <StaticResource x:Key="SplitButtonBackground" ResourceKey="AccentFillColorDefaultBrush"/>
                                     <StaticResource x:Key="SplitButtonBackgroundPointerOver" ResourceKey="AccentFillColorSecondaryBrush"/>
                                     <StaticResource x:Key="SplitButtonBackgroundPressed" ResourceKey="AccentFillColorTertiaryBrush"/>
                                     <!-- Foreground -->
                                     <StaticResource x:Key="SplitButtonForeground" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
                                     <StaticResource x:Key="SplitButtonForegroundPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
                                     <StaticResource x:Key="SplitButtonForegroundPressed" ResourceKey="TextOnAccentFillColorSecondaryBrush"/>
                                     <!-- Border -->
                                     <StaticResource x:Key="SplitButtonBorderBrush" ResourceKey="AccentControlElevationBorderBrush"/>
                                     <StaticResource x:Key="SplitButtonBorderBrushPointerOver" ResourceKey="AccentControlElevationBorderBrush"/>
                                     <!-- Secondary Button Foreground (Chevron) -->
                                     <StaticResource x:Key="SplitButtonForegroundSecondary" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
                                     <StaticResource x:Key="SplitButtonForegroundSecondaryPressed" ResourceKey="TextOnAccentFillColorSecondaryBrush"/>
                                 </SplitButton.Resources>
                                 <Grid>
                                     <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind local:DownloadPage.GetDownloadIconVisibility(Filename), Mode=OneTime}">
                                         <FontIcon Glyph="&#xE896;" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                         <TextBlock Text="Download" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                                     </StackPanel>
                                     <ProgressRing Width="16" Height="16" IsActive="True" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Visibility="{x:Bind local:DownloadPage.GetDownloadSpinnerVisibility(Filename), Mode=OneTime}"/>
                                 </Grid>
                                 <SplitButton.Flyout>
                                     <MenuFlyout Placement="Bottom">
                                         <MenuFlyoutItem Text="Download externally" Click="DownloadExternally_Click" DataContext="{x:Bind}">
                                             <MenuFlyoutItem.Icon>
                                                 <FontIcon Glyph="&#xE8A7;"/>
                                             </MenuFlyoutItem.Icon>
                                         </MenuFlyoutItem>
                                     </MenuFlyout>
                                 </SplitButton.Flyout>
                             </SplitButton>

                            <!-- Open Actions -->
                            <SplitButton Click="OpenDownloadedInstaller_Click"
                                         DataContext="{x:Bind}"
                                         Height="36"
                                         Width="136"
                                         VerticalAlignment="Center"
                                         Visibility="{x:Bind local:DownloadPage.GetOpenActionsVisibility(Filename), Mode=OneTime}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8E5;" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="Open file" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" />
                                </StackPanel>
                                <SplitButton.Flyout>
                                    <MenuFlyout Placement="Bottom">
                                        <MenuFlyoutItem Text="Open folder" Click="OpenDownloadedFolder_Click" DataContext="{x:Bind}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8DA;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </SplitButton.Flyout>
                            </SplitButton>
                        </Grid>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="0" Padding="36,36,36,0">
            <Grid ColumnDefinitions="*, Auto" RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Download"
                           Style="{StaticResource TitleTextBlockStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Grid.Row="1"
                           Text="Download and install official Blender versions."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="0" />
            </Grid>

            <!-- Dynamic Content Area (InfoBars and Search/Filters) -->
            <StackPanel Margin="0,28,0,0" Spacing="12">
                <StackPanel x:Name="InfoBarPanel" Spacing="4" Margin="0" Visibility="Collapsed">
                    <InfoBar x:Name="SuccessInfoBar"
                             IsOpen="False"
                             Title="Success"
                             Closed="InfoBar_Closed"
                             Severity="Success" />
                    <InfoBar x:Name="ErrorInfoBar"
                             IsOpen="False"
                             Title="Error"
                             Closed="InfoBar_Closed"
                             Severity="Error" />
                </StackPanel>

                <!-- Search and Filters Section -->
                <RelativePanel x:Name="SearchFiltersPanel" Margin="0">
                <!-- Left Side: Search & Refresh -->
                <StackPanel x:Name="SearchArea" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                            RelativePanel.AlignLeftWithPanel="True">
                    <AutoSuggestBox x:Name="SearchBox" Width="280"
                                    PlaceholderText="Search Blender versions..."
                                    TextChanged="SearchBox_TextChanged"
                                    VerticalAlignment="Center">
                        <AutoSuggestBox.QueryIcon>
                            <FontIcon Glyph="&#xE721;" FontSize="14" />
                        </AutoSuggestBox.QueryIcon>
                    </AutoSuggestBox>

                    <Button x:Name="RefreshButton" Click="RefreshButton_Click" ToolTipService.ToolTip="Refresh" Height="32" Width="32" Padding="0" VerticalAlignment="Center">
                        <Grid>
                            <FontIcon x:Name="RefreshButtonIcon" Glyph="&#xE72C;" FontSize="14" />
                            <ProgressRing x:Name="RefreshProgressRing" Width="16" Height="16" Visibility="Collapsed" IsActive="True"/>
                        </Grid>
                    </Button>

                    <TextBlock x:Name="ItemCountTextBlock" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>

                <StackPanel x:Name="FilterArea" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center"
                            RelativePanel.AlignRightWithPanel="True">
                    <controls:Segmented x:Name="TabSegmented" SelectionChanged="TabSegmented_SelectionChanged" SelectedIndex="0" VerticalAlignment="Center" MinHeight="32">
                        <controls:SegmentedItem Tag="download" ToolTipService.ToolTip="Download" MinWidth="40" MinHeight="32" Padding="0">
                            <FontIcon Glyph="&#xE896;" FontSize="14" VerticalAlignment="Center" />
                        </controls:SegmentedItem>
                        <controls:SegmentedItem Tag="installed" ToolTipService.ToolTip="Installed" MinWidth="40" MinHeight="32" Padding="0">
                            <FontIcon Glyph="&#xE7F4;" FontSize="14" VerticalAlignment="Center" />
                        </controls:SegmentedItem>
                    </controls:Segmented>

                    <!-- Filters DropDownButton -->
                    <DropDownButton AutomationProperties.Name="Filters" VerticalAlignment="Center" Height="32">
                        <DropDownButton.Content>
                            <FontIcon Glyph="&#xE71C;" FontSize="14"/>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <!-- Platform Group -->
                                <RadioMenuFlyoutItem x:Name="PlatformAllItem" Text="All Platforms" Tag="all" GroupName="PlatformGroup" IsChecked="True" Click="PlatformMenuItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="PlatformX64Item" Text="Windows x64" Tag="windows-x64" GroupName="PlatformGroup" Click="PlatformMenuItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="PlatformArm64Item" Text="ARM64" Tag="windows-arm64" GroupName="PlatformGroup" Click="PlatformMenuItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="PlatformX86Item" Text="x86" Tag="windows32" GroupName="PlatformGroup" Click="PlatformMenuItem_Click"/>

                                <MenuFlyoutSeparator/>

                                <!-- Type Group -->
                                <RadioMenuFlyoutItem x:Name="TypeAllItem" Text="All Types" Tag="all" GroupName="TypeGroup" IsChecked="True" Click="TypeMenuItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="TypeMsiItem" Text="MSI" Tag=".msi" GroupName="TypeGroup" Click="TypeMenuItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="TypeMsixItem" Text="MSIX" Tag=".msix" GroupName="TypeGroup" Click="TypeMenuItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="TypeZipItem" Text="ZIP" Tag=".zip" GroupName="TypeGroup" Click="TypeMenuItem_Click"/>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!-- Sort DropDownButton -->
                    <DropDownButton AutomationProperties.Name="Sort" VerticalAlignment="Center" Height="32">
                        <DropDownButton.Content>
                            <FontIcon Glyph="&#xE8CB;" FontSize="14"/>
                        </DropDownButton.Content>
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="Bottom">
                                <RadioMenuFlyoutItem x:Name="SortNewestItem" Text="Version (Newest First)" GroupName="SortGroup" IsChecked="True" Click="SortMenuItem_Click"/>
                                <RadioMenuFlyoutItem x:Name="SortOldestItem" Text="Version (Oldest First)" GroupName="SortGroup" Click="SortMenuItem_Click"/>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                </StackPanel>
            </RelativePanel>
        </StackPanel>
    </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,1,500" ColumnSpacing="12" Margin="36,0,36,24">
            <!-- Left Side: Versions List -->
            <Grid x:Name="LeftBodyGrid" Grid.Column="0">
                <Grid Margin="0,24,0,0">
                    <!-- GridView Mode GridView -->
                    <GridView x:Name="VersionsGridView"
                              SelectionChanged="VersionsListView_SelectionChanged"
                              SizeChanged="VersionsListView_SizeChanged"
                              ItemsSource="{Binding Source={StaticResource GroupedVersions}}"
                              Padding="0,0,0,0"
                              SelectionMode="Single"
                              IsSynchronizedWithCurrentItem="False"
                              ItemTemplate="{StaticResource DownloadGridViewTemplate}"
                              Visibility="Visible">
                        <GridView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderContainerStyle>
                                    <Style TargetType="GridViewHeaderItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="GridViewHeaderItem">
                                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Margin="0,0,16,0"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                          ContentTransitions="{TemplateBinding ContentTransitions}"
                                                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.HeaderContainerStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Key}"
                                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                                    Margin="{Binding Key, Converter={StaticResource DownloadGroupHeaderMarginConverter}}"/>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </GridView.GroupStyle>

                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0,0,0,0" />
                            </Style>
                        </GridView.ItemContainerStyle>
                    </GridView>

                    <!-- No Search Results Message -->
                    <StackPanel x:Name="NoSearchResultsPanel"
                                Spacing="12"
                                Padding="24"
                                MaxWidth="400"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE721;"
                                  FontSize="36"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                  Margin="0,0,0,8" />
                        <TextBlock Text="No results found"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="We couldn't find any Blender versions matching your search. Check the spelling or try different search terms."
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <Button Content="Clear search"
                                Click="ClearSearchButton_Click"
                                Style="{StaticResource DefaultButtonStyle}"
                                HorizontalAlignment="Center"
                                Margin="0,12,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Vertical Separator -->
            <Border x:Name="DetailsSeparator" Grid.Column="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,24,0,24" />

            <!-- Right Side: Details Panel -->
            <Grid x:Name="DetailsPanelOuterGrid" Grid.Column="2"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="24"
                  Margin="0,24,0,0">

                <Grid x:Name="DetailsGrid" Visibility="Collapsed" RowDefinitions="Auto,*,Auto">
                    <!-- 1. Header Section -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBlock x:Name="DetailVersionText" Grid.Column="0" Style="{StaticResource TitleTextBlockStyle}" Foreground="{ThemeResource TextFillColorPrimaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <TextBlock x:Name="DetailReleaseDateText" Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                            </Grid>

                            <InfoBar x:Name="DetailUpdateInfoBar"
                                     Severity="Informational"
                                     IsOpen="False"
                                     IsClosable="False"
                                     Margin="0,4,0,4">
                                <InfoBar.ActionButton>
                                    <Button x:Name="DetailUpdateButton" Content="Update" Click="DetailUpdateButton_Click" Style="{StaticResource AccentButtonStyle}"/>
                                </InfoBar.ActionButton>
                            </InfoBar>

                            <!-- View Download Page Button -->
                            <Button x:Name="DetailViewDownloadPage" Click="DetailViewDownloadPage_Click" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE71B;" FontSize="14" />
                                    <TextBlock Text="View Download Page" />
                                </StackPanel>
                            </Button>

                            <MenuFlyoutSeparator Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- 2. Scrollable Installers List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-12,0">
                        <StackPanel Spacing="16" Padding="0,0,12,0">
                            <!-- Latest Group -->
                            <StackPanel x:Name="LatestInstallersGroup" Spacing="8">
                                <TextBlock x:Name="LatestInstallersHeader" Text="Latest Version" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <ItemsRepeater x:Name="LatestInstallersList"
                                               ItemTemplate="{StaticResource DetailInstallerTemplate}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="8"/>
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                            </StackPanel>

                            <!-- Older Group -->
                            <StackPanel x:Name="OlderInstallersGroup" Spacing="8">
                                <TextBlock Text="Older Versions" Style="{StaticResource BodyStrongTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <ItemsRepeater x:Name="OlderInstallersList"
                                               ItemTemplate="{StaticResource DetailInstallerTemplate}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Vertical" Spacing="8"/>
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                            </StackPanel>

                            <!-- No Installers Found Message -->
                            <TextBlock x:Name="DetailNoInstallersMessage"
                                       Text="No installers found with selected filters."
                                       Style="{StaticResource BodyTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="20,40,20,40"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- 3. Bottom Progress & Completion Panel -->
                    <StackPanel x:Name="DetailBottomPanel" Grid.Row="2" Spacing="12" Margin="0,20,0,0" Visibility="Collapsed">
                        <!-- Progress Section -->
                        <StackPanel x:Name="DetailProgressPanel" Spacing="8" Visibility="Collapsed">
                            <ProgressBar x:Name="DetailProgressBar" Value="0" Maximum="100"/>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <TextBlock x:Name="DetailProgressText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="PauseResumeBtn" Click="PauseResumeBtn_Click" Style="{StaticResource DefaultButtonStyle}" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon x:Name="PauseResumeIcon" Glyph="&#xE769;" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="PauseResumeText" Text="Pause" Style="{StaticResource CaptionTextBlockStyle}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="DeleteDownloadBtn" Click="DeleteDownloadBtn_Click" Style="{StaticResource DefaultButtonStyle}" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="Delete" Style="{StaticResource CaptionTextBlockStyle}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Completion Section -->
                        <Grid x:Name="DetailCompletionPanel" Visibility="Collapsed" RowDefinitions="Auto,Auto" RowSpacing="12">
                            <TextBlock x:Name="CompletionMessageText" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Button x:Name="OpenInstallerBtn" Click="OpenInstallerBtn_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8E5;" FontSize="12"/>
                                        <TextBlock Text="Open Installer" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="OpenFolderBtn" Grid.Column="1" Click="OpenFolderBtn_Click" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8DA;" FontSize="12"/>
                                        <TextBlock Text="Open Folder" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Empty State for Details (No selection) -->
                <StackPanel x:Name="NoSelectionPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                    <FontIcon Glyph="&#xE9B9;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="No Version Selected" Style="{StaticResource BodyLargeStrongTextBlockStyle}" HorizontalAlignment="Center" />
                    <TextBlock Text="Select a Blender version from the list to view installers and download options." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center" MaxWidth="280" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
