<Page
    x:Class="BlendHub.Pages.BackupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedBackupItems" />
    </Page.Resources>

    <Grid Padding="36,36,36,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="0,0,0,10" ColumnDefinitions="*, Auto" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Backup Settings"
                           Style="{StaticResource TitleTextBlockStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Grid.Row="1"
                           Text="Save your Blender preferences, addons, and configurations."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel x:Name="ActionPanel" Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal"
                Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="StatusText" Text="" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Medium"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="BackupProgressBar" Value="0" Maximum="100" Height="4"
                        MinWidth="120" IsIndeterminate="False" Opacity="0" />
                </StackPanel>
                <Button x:Name="StartBackupButton"
                    Click="StartBackupButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Height="36"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="14" />
                        <TextBlock Text="Start Backup" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Info Bars -->
        <StackPanel x:Name="InfoBarPanel" Grid.Row="2" Spacing="4" Margin="0" HorizontalAlignment="Stretch">
            <InfoBar x:Name="WarningInfoBar" IsOpen="False" IsClosable="True" Severity="Warning"
                Title="" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
            <InfoBar x:Name="ErrorInfoBar" IsOpen="False" IsClosable="True" Severity="Error"
                Title="" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
            <InfoBar x:Name="SuccessInfoBar" IsOpen="False" IsClosable="True" Severity="Success"
                Title="Backup Complete" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
            VerticalContentAlignment="Stretch">
            <StackPanel Spacing="16" Padding="0">

                <StackPanel Spacing="6">
                    <!-- Select Blender Version -->
                    <controls:SettingsCard Header="Select Blender Version"
                        Description="Select which installed Blender version to backup.">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7B8;" />
                        </controls:SettingsCard.HeaderIcon>
                        <StackPanel Orientation="Vertical" Spacing="4">
                            <ComboBox x:Name="VersionComboBox" MinWidth="200"
                                HorizontalAlignment="Right"
                                SelectionChanged="VersionComboBox_SelectionChanged"
                                DisplayMemberPath="DisplayName" />
                            <TextBlock x:Name="VersionPathText"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                FontStyle="Italic"
                                TextWrapping="Wrap"
                                HorizontalAlignment="Right" />
                        </StackPanel>
                    </controls:SettingsCard>

                    <!-- Items to Include -->
                    <controls:SettingsExpander Header="Items to Include"
                        Description="Select which parts of the configuration to backup."
                        IsExpanded="True">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8A4;" />
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="60,16" CornerRadius="0">
                                <ItemsRepeater x:Name="BackupItemsRepeater"
                                    ItemsSource="{Binding Source={StaticResource GroupedBackupItems}}"
                                    HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="88" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Stretch" Margin="0">
                                                <TextBlock Text="{Binding Key}"
                                                     Style="{StaticResource BodyStrongTextBlockStyle}"
                                                     Margin="0,0,0,12"
                                                     Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                                <ItemsRepeater ItemsSource="{Binding Items}">
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate
                                                            x:DataType="models:ConfigItemViewModel">
                                                            <CheckBox Content="{x:Bind Name}"
                                                                IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                IsEnabled="{x:Bind IsExists}"
                                                                Margin="0,2,0,2"
                                                                ToolTipService.ToolTip="{x:Bind TooltipText}" />
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- Manage Backups -->
                    <controls:SettingsExpander x:Name="ManageBackupsExpander"
                        Header="Manage Backups"
                        Description="View, delete, or open your backup folder." IsExpanded="False" >
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8B7;" />
                        </controls:SettingsExpander.HeaderIcon>

                        <controls:SettingsExpander.Items>
                            <ItemsRepeater x:Name="BackupsListView">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical" Spacing="0" />
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <controls:SettingsCard Header="{Binding}"
                                            ContentAlignment="Right" Padding="60,16" CornerRadius="0">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Click="OpenItem_Click" Tag="{Binding}"
                                                    ToolTipService.ToolTip="Open folder">
                                                    <FontIcon Glyph="&#xED25;" FontSize="14" />
                                                </Button>
                                                <Button Click="DeleteItem_Click" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButtonStyle}"
                                                    ToolTipService.ToolTip="Delete backup">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                </Button>
                                                <Button Click="InfoItem_Click" Tag="{Binding}"
                                                    ToolTipService.ToolTip="View items">
                                                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                                                </Button>
                                            </StackPanel>
                                        </controls:SettingsCard>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <TeachingTip x:Name="ItemsInfoTeachingTip"
            Title="Backup Contents"
            IsLightDismissEnabled="True">
            <TeachingTip.Content>
                <ItemsRepeater ItemsSource="{Binding}" Margin="0,8,0,0">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" Orientation="Vertical" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Grid HorizontalAlignment="Stretch" Margin="0,2" Width="260">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <FontIcon Grid.Column="0" Glyph="{Binding StatusGlyph}" 
                                    Foreground="{Binding StatusBrush}"
                                    FontSize="14" Margin="0,0,12,0" />

                                <!-- Name -->
                                <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                    Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                <!-- Status Badge/Pill -->
                                <Border Grid.Column="2" Padding="8,2" CornerRadius="4"
                                    Background="{Binding StatusPillBackground}">
                                    <TextBlock Text="{Binding StatusText}" 
                                        Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"
                                        Foreground="{Binding StatusBrush}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </TeachingTip.Content>
        </TeachingTip>
    </Grid>
</Page>
