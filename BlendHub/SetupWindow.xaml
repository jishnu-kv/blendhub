<Window
    x:Class="BlendHub.SetupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Header & Modern Progress Indicator -->
        <Border Grid.Row="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="32,24,32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock 
                        x:Name="StepTitleText"
                        Text="Step 1 of 4: Your Name"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock 
                        Text="Setting up your personalized BlendHub workspace"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6" MinWidth="150">
                    <ProgressBar 
                        x:Name="ProgressIndicator"
                        Value="25"
                        Maximum="100"
                        Height="6"
                        CornerRadius="3" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Step Content Area -->
        <ScrollViewer 
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollMode="Disabled"
            Padding="32,24,32,24">
            
            <!-- Removed redundant inner margins to let borders expand to full available width -->
            <StackPanel HorizontalAlignment="Stretch" Spacing="24">
                    
                <!-- Step 1: Username -->
                <StackPanel x:Name="Step1Panel" Visibility="Visible" Spacing="16">
                    <TextBlock 
                        Text="Welcome to BlendHub! Let's start with your name."
                        FontSize="15"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock 
                                    Text="Your Name" 
                                    FontSize="16"
                                    FontWeight="SemiBold" />
                                <TextBlock 
                                    Text="This will be used to personalize your BlendHub experience and coordinate project workflows."
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <TextBox 
                                x:Name="UsernameTextBox"
                                PlaceholderText="Enter your name"
                                Text="{x:Bind Username, Mode=TwoWay}"
                                TextChanged="UsernameTextBox_TextChanged"
                                Height="36"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 2: Theme -->
                <StackPanel x:Name="Step2Panel" Visibility="Collapsed" Spacing="16">
                    <TextBlock 
                        Text="Choose how you want BlendHub to look and feel."
                        FontSize="15"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock 
                                    Text="Choose Your Theme" 
                                    FontSize="16"
                                    FontWeight="SemiBold" />
                                <TextBlock 
                                    Text="Select the visual styling that best suits your workplace environment."
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <StackPanel Spacing="12" Margin="0,8,0,0">
                                <RadioButton 
                                    x:Name="SystemThemeRadio"
                                    Content="Use system theme"
                                    GroupName="Theme"
                                    IsChecked="True"
                                    Checked="SystemThemeRadio_Checked" />
                                <RadioButton 
                                    x:Name="LightThemeRadio"
                                    Content="Light theme"
                                    GroupName="Theme"
                                    Checked="LightThemeRadio_Checked" />
                                <RadioButton 
                                    x:Name="DarkThemeRadio"
                                    Content="Dark theme"
                                    GroupName="Theme"
                                    Checked="DarkThemeRadio_Checked" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 3: Backup Location -->
                <StackPanel x:Name="Step3Panel" Visibility="Collapsed" Spacing="16">
                    <TextBlock 
                        Text="Choose where your project backups will be stored."
                        FontSize="15"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock 
                                    Text="Backup Location" 
                                    FontSize="16"
                                    FontWeight="SemiBold" />
                                <TextBlock 
                                    Text="Your project assets and version histories will be automatically preserved at this location."
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <TextBox 
                                    x:Name="BackupLocationTextBox"
                                    Text="{x:Bind BackupLocation, Mode=TwoWay}"
                                    IsReadOnly="True"
                                    Height="36"
                                    VerticalAlignment="Center" />
                                
                                <Button 
                                    x:Name="BrowseBackupButton"
                                    Content="Browse..."
                                    Grid.Column="1"
                                    Height="36"
                                    Padding="16,0"
                                    Click="BrowseBackupButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 4: Blender Installations -->
                <StackPanel x:Name="Step4Panel" Visibility="Collapsed" Spacing="16">
                    <TextBlock 
                        Text="We found these Blender installations on your system. You can add more later."
                        FontSize="15"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    
                    <Border 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock 
                                    Text="Blender Installations" 
                                    FontSize="16"
                                    FontWeight="SemiBold" />
                                <TextBlock 
                                    Text="These installed Blender configurations were auto-discovered. Manage or customize them below."
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            
                            <ScrollViewer Height="140" VerticalScrollBarVisibility="Auto" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="12,8">
                                <StackPanel x:Name="DetectedBlendersPanel" Spacing="6">
                                    <!-- Detected blenders will be added here programmatically -->
                                </StackPanel>
                            </ScrollViewer>
                            
                            <Button 
                                x:Name="AddBlenderButton"
                                Content="Add Blender Installation"
                                Style="{StaticResource AccentButtonStyle}"
                                Height="36"
                                Padding="16,0"
                                HorizontalAlignment="Left"
                                Click="AddBlenderButton_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Navigation Buttons & Styled Bottom Bar -->
        <Border 
            Grid.Row="2"
            Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="32,20,32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <Button 
                    x:Name="SkipButton"
                    Content="Skip Setup"
                    Style="{StaticResource DefaultButtonStyle}"
                    Grid.Column="0"
                    Height="36"
                    Padding="16,0"
                    Click="SkipSetupButton_Click" />
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button 
                        x:Name="PreviousButton"
                        Content="Previous"
                        Style="{StaticResource DefaultButtonStyle}"
                        Height="36"
                        Padding="16,0"
                        Margin="0,0,12,0"
                        Click="PreviousButton_Click"
                        IsEnabled="False" />
                    
                    <Button 
                        x:Name="NextButton"
                        Content="Next"
                        Style="{StaticResource AccentButtonStyle}"
                        Height="36"
                        Padding="24,0"
                        Click="NextButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
