<UserControl
    x:Class="BlendHub.Dialogs.EditProjectDialogContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Dialogs"
    xmlns:models="using:BlendHub.Models"
    xmlns:services="using:BlendHub.Services"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinWidth="500" MaxWidth="600" Padding="0">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
            <StackPanel Spacing="20">
                
                <!-- Project Details Section -->
                <StackPanel Spacing="16">
                    <!-- Section Header -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE70F;" 
                                  FontSize="18" 
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Project Details" 
                                   FontWeight="SemiBold" 
                                   FontSize="16"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Project Name (Disabled) -->
                    <TextBox x:Name="ProjectNameTextBox" 
                             Header="Project Name" 
                             IsEnabled="False" />
                    
                    <!-- Blender Version (Editable) -->
                    <ComboBox x:Name="BlenderVersionComboBox" 
                              Header="Blender Version" 
                              PlaceholderText="Select installed version..." 
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="services:BlenderVersionInfo">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7F4;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind DisplayName}" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Auto Update Primary Blend File (ToggleSwitch) -->
                    <ToggleSwitch x:Name="AutoUpdatePrimaryBlendToggle"
                                  Header="Auto Update Primary .blend File"
                                  Margin="0,4,0,0"/>

                    <!-- Primary Blend File (Editable) -->
                    <ComboBox x:Name="PrimaryBlendFileComboBox" 
                              Header="Primary Blend File" 
                              PlaceholderText="Select primary .blend file..." 
                              HorizontalAlignment="Stretch" />
                    
                    <!-- Project Location (Disabled) -->
                    <TextBox x:Name="ProjectPathTextBox" 
                             Header="Project Location" 
                             IsEnabled="False" />
                </StackPanel>

                <!-- Separator -->
                <Border Height="1" 
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        HorizontalAlignment="Stretch" />

                <!-- Folder Structure Section -->
                <StackPanel Spacing="12">
                    <!-- Section Header -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xED25;" 
                                  FontSize="18"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Folder Structure" 
                                   FontWeight="SemiBold" 
                                   FontSize="16"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Manage the folders in your project directory." 
                               FontSize="12" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ItemsControl x:Name="FoldersItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ProjectFolder">
                                <Grid Margin="0,4" ColumnDefinitions="Auto, *, Auto">
                                    <TextBlock Text="{x:Bind Label}" 
                                               VerticalAlignment="Center" 
                                               Width="70" 
                                               Margin="0,0,8,0"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               FontSize="12"/>
                                    <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             VerticalAlignment="Center" 
                                             Grid.Column="1"
                                             PlaceholderText="Folder name" />
                                    <Button x:Name="DeleteButton"
                                            Click="DeleteFolder_Click" 
                                            Grid.Column="2" 
                                            Margin="8,0,0,0"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            ToolTipService.ToolTip="Remove folder">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Click="AddFolder_Click" 
                            Style="{StaticResource DefaultButtonStyle}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="Add Custom Folder" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Separator -->
                <Border Height="1" 
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" 
                        HorizontalAlignment="Stretch" />

                <!-- File Launchers Section -->
                <StackPanel Spacing="12">
                    <!-- Section Header -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE7AC;" 
                                  FontSize="18"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="File Launchers" 
                                   FontWeight="SemiBold" 
                                   FontSize="16"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Associate file extensions with applications to open them directly from the project." 
                               FontSize="12" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <ItemsControl x:Name="LaunchersItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:FileLauncher">
                                <Grid Margin="0,6" ColumnDefinitions="100, *, Auto, Auto">
                                    <TextBox Text="{Binding Extension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             PlaceholderText=".ext" 
                                             VerticalAlignment="Center" 
                                             Grid.Column="0" 
                                             Margin="0,0,8,0" />
                                    <TextBox Text="{Binding ProgramPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                             PlaceholderText="Program path..." 
                                             IsReadOnly="True"
                                             VerticalAlignment="Center" 
                                             Grid.Column="1" />
                                    <Button Click="BrowseLauncher_Click" 
                                            Grid.Column="2" 
                                            Margin="4,0,0,0"
                                            ToolTipService.ToolTip="Browse Program"
                                            Style="{StaticResource SubtleButtonStyle}">
                                        <FontIcon Glyph="&#xED25;" FontSize="14" />
                                    </Button>
                                    <Button Click="DeleteLauncher_Click" 
                                            Grid.Column="3" 
                                            Margin="4,0,0,0"
                                            ToolTipService.ToolTip="Remove launcher"
                                            Style="{StaticResource SubtleButtonStyle}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Click="AddLauncher_Click" 
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource DefaultButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="Add File Launcher" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Validation Warning -->
                <InfoBar x:Name="WarningInfoBar" IsOpen="False" IsClosable="False" Severity="Warning" Title="Missing Information" Message="" Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
