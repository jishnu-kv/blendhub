<Page
    x:Class="BlendHub.Pages.RestorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedRestoreItems" />
    </Page.Resources>

    <Grid Padding="36,36,36,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="0,0,0,10" ColumnDefinitions="*, Auto" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Restore Settings"
                           Style="{StaticResource TitleTextBlockStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Grid.Row="1"
                           Text="Restore your preferences and config from previous backups."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel x:Name="ActionPanel" Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal"
                Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="StatusText" Text="" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Medium"
                        HorizontalAlignment="Right"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="RestoreProgressBar" Value="0" Maximum="100" Height="4"
                        MinWidth="120" IsIndeterminate="False" Opacity="0" />
                </StackPanel>
                <Button x:Name="StartRestoreButton"
                    Click="StartRestoreButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Height="36"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE81C;" FontSize="14" />
                        <TextBlock Text="Start Restore" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Info Bars -->
        <StackPanel x:Name="InfoBarPanel" Grid.Row="2" Spacing="4" Margin="0" HorizontalAlignment="Stretch">
            <InfoBar x:Name="WarningInfoBar" IsOpen="False" IsClosable="True" Severity="Warning"
                Title="" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
            <InfoBar x:Name="ErrorInfoBar" IsOpen="False" IsClosable="True" Severity="Error"
                Title="" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
            <InfoBar x:Name="SuccessInfoBar" IsOpen="False" IsClosable="True" Severity="Success"
                Title="Restore Complete" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
            VerticalContentAlignment="Stretch">
            <StackPanel Spacing="16" Padding="0">

                <StackPanel Spacing="6">
                    <!-- Select Backup -->
                    <controls:SettingsCard x:Name="BackupSelectionCard" Header="Select Backup"
                        Description="Select the backup to restore from.">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7B8;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="BackupNameComboBox" MinWidth="240"
                            PlaceholderText="Select backup..." HorizontalAlignment="Right"
                            SelectionChanged="BackupNameComboBox_SelectionChanged" />
                    </controls:SettingsCard>

                    <!-- Restore Destination -->
                    <controls:SettingsCard x:Name="RestoreDestinationCard"
                        Header="Restore Destination"
                        Description="Choose the installed Blender version you want to restore these settings to.">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE8DE;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="TargetVersionComboBox" MinWidth="200"
                            DisplayMemberPath="DisplayName"
                            SelectionChanged="TargetVersionComboBox_SelectionChanged" />
                    </controls:SettingsCard>

                    <!-- Items to Include -->
                    <controls:SettingsExpander x:Name="ItemsExpander" Header="Items to Include"
                        Description="Select which parts of the configuration to restore."
                        IsExpanded="True">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8A4;" />
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="60,16" CornerRadius="0">
                                <ItemsRepeater x:Name="RestoreItemsRepeater"
                                    ItemsSource="{Binding Source={StaticResource GroupedRestoreItems}}"
                                    HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="88" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding Key}"
                                                     Style="{StaticResource BodyStrongTextBlockStyle}"
                                                     Margin="0,0,0,12"
                                                     Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                                <ItemsRepeater ItemsSource="{Binding Items}">
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate
                                                            x:DataType="models:ConfigItemViewModel">
                                                            <CheckBox Content="{x:Bind Name}"
                                                                IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                IsEnabled="{x:Bind IsExists}"
                                                                Margin="0,2,0,2"
                                                                ToolTipService.ToolTip="{x:Bind TooltipText}" />
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
