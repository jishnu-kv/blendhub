<Page
    x:Class="BlendHub.Pages.SyncPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedSyncItems" />
    </Page.Resources>

    <Grid Padding="36,36,36,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="HeaderGrid" Grid.Row="0" ColumnDefinitions="*, Auto" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <TextBlock x:Uid="SyncPage_Title"
                           Style="{StaticResource TitleTextBlockStyle}"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Grid.Row="1"
                           x:Uid="SyncPage_Subtitle"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel x:Name="ActionPanel" Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal"
                Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ProgressBar x:Name="SyncProgressBar" Value="{x:Bind ViewModel.SyncProgress, Mode=OneWay}" Maximum="100" Height="4"
                    MinWidth="120" IsIndeterminate="{x:Bind ViewModel.IsSyncing, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsSyncing, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" VerticalAlignment="Center" />
                <Button x:Name="StartSyncButton"
                    Click="StartSyncButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Height="36"
                    VerticalAlignment="Center"
                    AutomationProperties.AutomationId="StartSyncButton"
                    IsEnabled="{x:Bind ViewModel.IsStartSyncEnabled, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE895;" FontSize="14" />
                        <TextBlock x:Uid="SyncPage_StartSyncText" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Info Bars -->
        <Grid x:Name="InfoBarPanel" Grid.Row="2" Margin="0" HorizontalAlignment="Stretch">
            <InfoBar x:Name="WarningInfoBar" Margin="0,20,0,20" IsOpen="{x:Bind ViewModel.IsWarningOpen, Mode=TwoWay}" IsClosable="{x:Bind ViewModel.IsWarningClosable, Mode=OneWay}" Severity="{x:Bind ViewModel.WarningSeverity, Mode=OneWay}"
                Title="{x:Bind ViewModel.WarningTitle, Mode=OneWay}" Message="{x:Bind ViewModel.WarningMessage, Mode=OneWay}" HorizontalAlignment="Stretch" Closed="InfoBar_Closed" />
            <InfoBar x:Name="ErrorInfoBar" Margin="0,20,0,20" IsOpen="{x:Bind ViewModel.IsErrorOpen, Mode=TwoWay}" IsClosable="True" Severity="Error"
                Title="Error" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" HorizontalAlignment="Stretch" Closed="InfoBar_Closed" />
            <InfoBar x:Name="SuccessInfoBar" Margin="0,20,0,20" IsOpen="{x:Bind ViewModel.IsSuccessOpen, Mode=TwoWay}" IsClosable="True" Severity="Success"
                Title="Sync Complete" Message="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}" HorizontalAlignment="Stretch" Closed="InfoBar_Closed">
                <InfoBar.ActionButton>
                    <Button x:Name="LaunchBlenderButton" Content="Launch Blender" Click="LaunchBlenderButton_Click"
                            AutomationProperties.AutomationId="LaunchBlenderButton"
                            AutomationProperties.Name="Launch Blender" />
                </InfoBar.ActionButton>
            </InfoBar>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
            VerticalContentAlignment="Stretch" Padding="0,6,0,0">
            <StackPanel Spacing="16" Padding="0">

                <StackPanel Spacing="4">
                    <!-- Source Blender Version -->
                    <controls:SettingsCard x:Name="SourceVersionCard" x:Uid="SyncPage_SourceVersionCard"
                        IsEnabled="{x:Bind ViewModel.IsSourceCardEnabled, Mode=OneWay}">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7B8;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="SourceVersionComboBox" MinWidth="200"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.SourceVersionsList, Mode=OneWay}"
                            SelectedItem="{x:Bind ViewModel.SelectedSource, Mode=TwoWay}"
                            SelectionChanged="SourceVersionComboBox_SelectionChanged"
                            HorizontalAlignment="Right"
                            AutomationProperties.AutomationId="SourceVersionComboBox"
                            AutomationProperties.Name="Source Blender Version" />
                    </controls:SettingsCard>

                    <!-- Target Blender Versions -->
                    <controls:SettingsExpander x:Name="TargetVersionsExpander" x:Uid="SyncPage_TargetVersionsExpander"
                        IsEnabled="{x:Bind ViewModel.IsTargetVersionsExpanderEnabled, Mode=OneWay}"
                        IsExpanded="True">
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                HorizontalAlignment="Stretch" Padding="60,16" CornerRadius="0">
                                <ItemsRepeater x:Name="TargetVersionsListView"
                                    ItemsSource="{x:Bind ViewModel.TargetVersions, Mode=OneWay}"
                                    HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="160"
                                            Orientation="Horizontal" ItemsStretch="Fill" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:TargetVersionViewModel">
                                            <CheckBox Content="{x:Bind DisplayName}"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                VerticalAlignment="Center" Margin="0,6,12,6" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- Items to Sync -->
                    <controls:SettingsExpander x:Name="ItemsToSyncExpander" x:Uid="SyncPage_ItemsToSyncExpander"
                        IsEnabled="{x:Bind ViewModel.IsItemsToSyncExpanderEnabled, Mode=OneWay}"
                        IsExpanded="True">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8A4;" />
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="60,16" CornerRadius="0">
                                <ItemsRepeater x:Name="SyncItemsRepeater"
                                    ItemsSource="{Binding Source={StaticResource GroupedSyncItems}}"
                                    HorizontalAlignment="Stretch"
                                    ItemTemplate="{StaticResource GroupedConfigItemsTemplate}">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="88" />
                                    </ItemsRepeater.Layout>
                                </ItemsRepeater>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
