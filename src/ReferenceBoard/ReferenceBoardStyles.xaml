	<!-- Item style for the Pen color palette -->
	<Style x:Key="ColorPaletteItemStyle" TargetType="GridViewItem">
		<Setter Property="MinWidth" Value="36" />
		<Setter Property="MinHeight" Value="36" />
		<Setter Property="Margin" Value="2" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="IsTabStop" Value="False" />
		<Setter Property="UseSystemFocusVisuals" Value="False" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="GridViewItem">
					<Grid x:Name="RootGrid" Background="Transparent" Width="44" Height="44">
						<!-- Selected item ring indicator -->
						<Ellipse x:Name="SelectionIndicator"
							Stroke="{ThemeResource AccentFillColorDefaultBrush}"
							StrokeThickness="2.5"
							Fill="Transparent"
							Width="40" Height="40"
							Opacity="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToDoubleConverter}}"
							Canvas.ZIndex="1"
							HorizontalAlignment="Center"
							VerticalAlignment="Center" />

						<!-- Color Palette -->
						<Ellipse x:Name="ColorCircle"
							Fill="{Binding Content.Brush, RelativeSource={RelativeSource TemplatedParent}}"
							Width="28" Height="28"
							Canvas.ZIndex="0"
							HorizontalAlignment="Center"
							VerticalAlignment="Center">
							<Ellipse.RenderTransform>
								<ScaleTransform x:Name="ScaleTransform" CenterX="14" CenterY="14" />
							</Ellipse.RenderTransform>
						</Ellipse>

						<!-- Hover and press animation states -->
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleX" To="1.0"
											Duration="0:0:0.1" />
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleY" To="1.0"
											Duration="0:0:0.1" />
									</Storyboard>
								</VisualState>
								<VisualState x:Name="PointerOver">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleX" To="1.2"
											Duration="0:0:0.1" />
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleY" To="1.2"
											Duration="0:0:0.1" />
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Pressed">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleX" To="1.1"
											Duration="0:0:0.1" />
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleY" To="1.1"
											Duration="0:0:0.1" />
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Item style for the Shape color/fill palette (includes 'None' option) -->
	<Style x:Key="ShapeColorPaletteItemStyle" TargetType="GridViewItem">
		<Setter Property="MinWidth" Value="44" />
		<Setter Property="MinHeight" Value="44" />
		<Setter Property="Margin" Value="2" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="IsTabStop" Value="False" />
		<Setter Property="UseSystemFocusVisuals" Value="False" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="GridViewItem">
					<Grid x:Name="RootGrid" Background="Transparent" Width="44" Height="44">
						<!-- Selected item ring indicator -->
						<Ellipse x:Name="SelectionIndicator"
							Stroke="{ThemeResource AccentFillColorDefaultBrush}"
							StrokeThickness="2.5"
							Fill="Transparent"
							Width="40" Height="40"
							Opacity="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToDoubleConverter}}"
							Canvas.ZIndex="1"
							HorizontalAlignment="Center"
							VerticalAlignment="Center" />

						<!-- Color Circle (Hidden if 'None') -->
						<Ellipse x:Name="ColorCircle"
							Fill="{Binding Content.Brush, RelativeSource={RelativeSource TemplatedParent}}"
							Width="28" Height="28"
							Canvas.ZIndex="0"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Opacity="{Binding Content.IsNone, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToDoubleConverter}, ConverterParameter=Inverse}">
							<Ellipse.RenderTransform>
								<ScaleTransform x:Name="ScaleTransform" CenterX="14" CenterY="14" />
							</Ellipse.RenderTransform>
						</Ellipse>

						<!-- 'None' Icon (Visible only if 'None') -->
						<Viewbox Width="36" Height="36"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Opacity="{Binding Content.IsNone, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToDoubleConverter}}">
							<FontIcon Glyph="&#xF140;"
								Foreground="{ThemeResource TextFillColorPrimaryBrush}">
								<FontIcon.RenderTransform>
									<TranslateTransform X="0.5" Y="-0.5" />
								</FontIcon.RenderTransform>
							</FontIcon>
						</Viewbox>

						<!-- Hover and press animation states -->
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleX" To="1.0"
											Duration="0:0:0.1" />
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleY" To="1.0"
											Duration="0:0:0.1" />
									</Storyboard>
								</VisualState>
								<VisualState x:Name="PointerOver">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleX" To="1.2"
											Duration="0:0:0.1" />
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleY" To="1.2"
											Duration="0:0:0.1" />
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Pressed">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleX" To="1.1"
											Duration="0:0:0.1" />
										<DoubleAnimation Storyboard.TargetName="ScaleTransform"
											Storyboard.TargetProperty="ScaleY" To="1.1"
											Duration="0:0:0.1" />
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Generic Toolbar Button Style -->
	<Style x:Key="ToolbarButtonStyle" TargetType="Button">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="Width" Value="32" />
		<Setter Property="Height" Value="32" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Grid x:Name="RootGrid" Background="{TemplateBinding Background}"
						CornerRadius="4">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames
											Storyboard.TargetName="RootGrid"
											Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
												Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Pressed">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames
											Storyboard.TargetName="RootGrid"
											Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
												Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Disabled">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ContentPresenter"
											Storyboard.TargetProperty="Opacity" To="0.4"
											Duration="0" />
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
						<ContentPresenter x:Name="ContentPresenter"
							Content="{TemplateBinding Content}"
							ContentTemplate="{TemplateBinding ContentTemplate}"
							Padding="{TemplateBinding Padding}"
							HorizontalAlignment="Center"
							VerticalAlignment="Center" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Generic Toolbar ToggleButton Style -->
	<Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="Width" Value="32" />
		<Setter Property="Height" Value="32" />
		<Setter Property="HorizontalAlignment" Value="Center" />
		<Setter Property="VerticalAlignment" Value="Center" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="ToggleButton">
					<Grid x:Name="RootGrid" Background="{TemplateBinding Background}"
						CornerRadius="4">
						<VisualStateManager.VisualStateGroups>
							<VisualStateGroup x:Name="CommonStates">
								<VisualState x:Name="Normal" />
								<VisualState x:Name="PointerOver">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames
											Storyboard.TargetName="RootGrid"
											Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
												Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Pressed">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames
											Storyboard.TargetName="RootGrid"
											Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
												Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Disabled">
									<Storyboard>
										<DoubleAnimation Storyboard.TargetName="ContentPresenter"
											Storyboard.TargetProperty="Opacity" To="0.4"
											Duration="0" />
									</Storyboard>
								</VisualState>
							</VisualStateGroup>
							<VisualStateGroup x:Name="CheckStates">
								<VisualState x:Name="Unchecked" />
								<VisualState x:Name="Checked">
									<Storyboard>
										<ObjectAnimationUsingKeyFrames
											Storyboard.TargetName="RootGrid"
											Storyboard.TargetProperty="Background">
											<DiscreteObjectKeyFrame KeyTime="0"
												Value="{ThemeResource ToggleButtonBackgroundChecked}" />
										</ObjectAnimationUsingKeyFrames>
									</Storyboard>
								</VisualState>
								<VisualState x:Name="Indeterminate" />
							</VisualStateGroup>
						</VisualStateManager.VisualStateGroups>
						<ContentPresenter x:Name="ContentPresenter"
							Content="{TemplateBinding Content}"
							ContentTemplate="{TemplateBinding ContentTemplate}"
							Padding="{TemplateBinding Padding}"
							HorizontalAlignment="Center"
							VerticalAlignment="Center" />
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<!-- Unified Board Item Style -->
	<Style x:Key="BoardItemBaseStyle" TargetType="controls:BoardItemBase">
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="controls:BoardItemBase">
					<Grid x:Name="TemplateRootGrid" Background="Transparent">
						<Grid.RenderTransform>
							<TransformGroup>
								<RotateTransform x:Name="RotationTransform" Angle="0" CenterX="0.5"
									CenterY="0.5" />
								<TranslateTransform x:Name="TranslateTransform" />
							</TransformGroup>
						</Grid.RenderTransform>

						<ContentPresenter x:Name="ContentPresenter"
							HorizontalContentAlignment="Stretch"
							VerticalContentAlignment="Stretch" />

						<!-- Selection Outline -->
						<Grid x:Name="SelectionOutline" Visibility="Collapsed">
							<Rectangle x:Name="SelectionRect"
								Stroke="{ThemeResource SystemControlForegroundBaseHighBrush}"
								StrokeThickness="2" Opacity="0.5" />
						</Grid>

						<Grid x:Name="ResizeHandles" Visibility="Collapsed">
							<Grid x:Name="RegularHandles">
								<Grid x:Name="RotateHandle" Tag="Rotate" Width="36" Height="36"
									HorizontalAlignment="Center" VerticalAlignment="Top"
									Margin="0,-48,0,0" Background="Transparent"
									RenderTransformOrigin="0.5,0.5">
									<Ellipse x:Name="RotateHandleVisual" Width="28" Height="28"
										Fill="{ThemeResource ControlFillColorDefaultBrush}"
										HorizontalAlignment="Center" VerticalAlignment="Center" />
									<FontIcon Glyph="&#xE7AD;" FontSize="14"
										Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
										HorizontalAlignment="Center" VerticalAlignment="Center" />
								</Grid>
								<Grid x:Name="TopLeftHandle" Width="30" Height="30"
									HorizontalAlignment="Left" VerticalAlignment="Top"
									Margin="-15,-15,0,0" Background="Transparent" Tag="TopLeft">
									<Ellipse x:Name="TopLeftVisual" Width="12" Height="12"
										Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
										Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
										StrokeThickness="1.5"
										HorizontalAlignment="Center" VerticalAlignment="Center"
										IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" />
								</Grid>
								<Grid x:Name="TopRightHandle" Width="30" Height="30"
									HorizontalAlignment="Right" VerticalAlignment="Top"
									Margin="0,-15,-15,0" Background="Transparent" Tag="TopRight">
									<Ellipse x:Name="TopRightVisual" Width="12" Height="12"
										Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
										Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
										StrokeThickness="1.5"
										HorizontalAlignment="Center" VerticalAlignment="Center"
										IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" />
								</Grid>
								<Grid x:Name="BottomLeftHandle" Width="30" Height="30"
									HorizontalAlignment="Left" VerticalAlignment="Bottom"
									Margin="-15,0,0,-15" Background="Transparent" Tag="BottomLeft">
									<Ellipse x:Name="BottomLeftVisual" Width="12" Height="12"
										Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
										Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
										StrokeThickness="1.5"
										HorizontalAlignment="Center" VerticalAlignment="Center"
										IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" />
								</Grid>
								<Grid x:Name="BottomRightHandle" Width="30" Height="30"
									HorizontalAlignment="Right" VerticalAlignment="Bottom"
									Margin="0,0,-15,-15" Background="Transparent" Tag="BottomRight">
									<Ellipse x:Name="BottomRightVisual" Width="12" Height="12"
										Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
										Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
										StrokeThickness="1.5"
										HorizontalAlignment="Center" VerticalAlignment="Center"
										IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" />
								</Grid>
							</Grid>
							<Canvas x:Name="LineHandles" Visibility="Collapsed">
								<Grid x:Name="StartHandle" Width="30" Height="30"
									Margin="-15,-15,0,0" Background="Transparent" Tag="Start">
									<Ellipse x:Name="StartVisual" Width="12" Height="12"
										Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
										Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
										StrokeThickness="1.5"
										HorizontalAlignment="Center" VerticalAlignment="Center"
										IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" />
								</Grid>
								<Grid x:Name="EndHandle" Width="30" Height="30" Margin="-15,-15,0,0"
									Background="Transparent" Tag="End">
									<Ellipse x:Name="EndVisual" Width="12" Height="12"
										Fill="{ThemeResource SystemControlForegroundBaseHighBrush}"
										Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
										StrokeThickness="1.5"
										HorizontalAlignment="Center" VerticalAlignment="Center"
										IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" />
								</Grid>
							</Canvas>
						</Grid>

						<!-- Floating Toolbar -->
						<Canvas>
							<Border x:Name="FloatingToolbar"
								Background="{ThemeResource LayerFillColorDefaultBrush}"
								BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
								BorderThickness="1"
								CornerRadius="6" Padding="4" Visibility="Collapsed"
								RenderTransformOrigin="0,1">
								<Border.RenderTransform>
									<CompositeTransform x:Name="ToolbarScaleTransform" ScaleX="1"
										ScaleY="1" />
								</Border.RenderTransform>
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*" />
										<ColumnDefinition Width="Auto" />
									</Grid.ColumnDefinitions>

									<!-- Dynamic Content for item-specific buttons (e.g. Flip) -->
									<ContentControl x:Name="ItemSpecificToolbarContent"
										HorizontalAlignment="Stretch" VerticalAlignment="Top"
										HorizontalContentAlignment="Stretch" />

									<StackPanel Grid.Column="1" Orientation="Horizontal"
										VerticalAlignment="Top" Spacing="0">
										<AppBarSeparator x:Name="ToolbarSeparator"
											Visibility="Collapsed" Margin="4,4" />

										<Button x:Name="ForwardButton" Width="32" Height="32"
											Padding="0" ToolTipService.ToolTip="Bring Forward"
											Background="Transparent" BorderThickness="0">
											<Viewbox Width="18" Height="18">
												<Canvas Width="24" Height="24">
													<Path
														Data="{StaticResource IconPathPositionToFront}"
														Fill="{ThemeResource TextFillColorPrimaryBrush}" />
												</Canvas>
											</Viewbox>
										</Button>
										<Button x:Name="BackwardButton" Width="32" Height="32"
											Padding="0" ToolTipService.ToolTip="Send Backward"
											Background="Transparent" BorderThickness="0">
											<Viewbox Width="18" Height="18">
												<Canvas Width="24" Height="24">
													<Path
														Data="{StaticResource IconPathPositionToBack}"
														Fill="{ThemeResource TextFillColorPrimaryBrush}" />
												</Canvas>
											</Viewbox>
										</Button>

										<AppBarSeparator x:Name="LockSeparator" Visibility="Visible"
											Margin="4,4" />

										<Button x:Name="LockButton" Width="32" Height="32"
											Padding="0" ToolTipService.ToolTip="Lock/Unlock"
											Background="Transparent" BorderThickness="0">
											<FontIcon x:Name="LockIcon" Glyph="&#xE72E;"
												FontSize="14" />
										</Button>

										<AppBarSeparator Margin="4,4" />
										<Button x:Name="DeleteButton" Width="32" Height="32"
											Padding="0" ToolTipService.ToolTip="Delete"
											Background="Transparent" BorderThickness="0">
											<FontIcon Glyph="&#xE74D;" FontSize="14"
												Foreground="IndianRed" />
										</Button>
									</StackPanel>
								</Grid>
							</Border>
						</Canvas>
					</Grid>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style TargetType="controls:ImageItemControl" BasedOn="{StaticResource BoardItemBaseStyle}" />
	<Style TargetType="controls:ShapeItemControl" BasedOn="{StaticResource BoardItemBaseStyle}" />
	<Style TargetType="controls:PenItemControl" BasedOn="{StaticResource BoardItemBaseStyle}" />
	<Style TargetType="controls:TextItemControl" BasedOn="{StaticResource BoardItemBaseStyle}" />

</ResourceDictionary>
