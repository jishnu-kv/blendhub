<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlendHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="BlendHub">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- WinUI 3 Gallery-style TitleBar -->
        <TitleBar
            x:Name="AppTitleBar"
            Title="BlendHub"
            IsBackButtonVisible="False"
            IsPaneToggleButtonVisible="False"
            PaneToggleRequested="AppTitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="ms-appx:///Assets/logo.png" />
            </TitleBar.IconSource>
            <TitleBar.Content>
                <Grid />
            </TitleBar.Content>
        </TitleBar>

        <!-- NavigationView -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            Canvas.ZIndex="0"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsBackEnabled="False"
            AlwaysShowHeader="False"
            IsSettingsVisible="False"
            IsTabStop="False"
            IsPaneOpen="False"
            DisplayModeChanged="NavView_DisplayModeChanged"
            SelectionChanged="NavView_SelectionChanged"
            ItemInvoked="NavView_ItemInvoked">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="HomeItem" Content="Home" Tag="home"
                                    AutomationProperties.AutomationId="HomeItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <!-- Workspace Section -->
                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Workspace" />
                <NavigationViewItem x:Name="ProjectItem" Content="Projects" Tag="project"
                                    AutomationProperties.AutomationId="ProjectItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE838;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="ReferenceBoardItem" Content="Reference Board" Tag="referenceboard"
                                    AutomationProperties.AutomationId="ReferenceBoardItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Blender" />
                <NavigationViewItem x:Name="DownloadItem" Content="Download" Tag="download"
                                    AutomationProperties.AutomationId="DownloadItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE896;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="AddonsItem" Content="Addons" Tag="addons"
                                    AutomationProperties.AutomationId="AddonsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA86;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Backup & Recovery Section -->
                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Backup &amp; Sync" />
                <NavigationViewItem x:Name="BackupItem" Content="Backup" Tag="backup"
                                    AutomationProperties.AutomationId="BackupItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="RestoreItem" Content="Restore" Tag="restore"
                                    AutomationProperties.AutomationId="RestoreItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SyncItem" Content="Sync" Tag="sync"
                                    AutomationProperties.AutomationId="SyncItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE895;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="FeedbackItem" 
                                    Content="Feedback" 
                                    Tag="feedback"
                                    SelectsOnInvoked="False"
                                    AutomationProperties.AutomationId="FeedbackItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xED15;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsItem" Content="Settings" Tag="settings" AutomationProperties.AutomationId="SettingsItem">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="ContentFrameInternal"
                   Navigated="ContentFrame_Navigated" />
        </NavigationView>
    </Grid>
</Window>


