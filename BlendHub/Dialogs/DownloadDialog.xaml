<UserControl
    x:Class="BlendHub.Dialogs.DownloadDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Dialogs"
    xmlns:models="using:BlendHub.Models"
    xmlns:converters="using:BlendHub.Converters">
    
    <UserControl.Resources>
        <converters:BytesToSizeConverter x:Key="BytesToSizeConverter" />
        <converters:PlatformConverter x:Key="PlatformConverter" />
    </UserControl.Resources>
    
    <StackPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinWidth="750" MaxWidth="800" Spacing="16">
        <!-- Header: Version -->
        <TextBlock x:Name="DialogVersionText"
                   FontSize="16" 
                   FontWeight="SemiBold"/>

        <!-- Filters Row -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Platform Filter -->
            <ComboBox x:Name="DialogPlatformComboBox"
                      Grid.Column="0"
                      Width="160"
                      SelectionChanged="DialogPlatformComboBox_SelectionChanged">
                <ComboBoxItem Content="Windows x64" Tag="windows-x64" IsSelected="True"/>
                <ComboBoxItem Content="ARM64" Tag="windows-arm64"/>
                <ComboBoxItem Content="x86" Tag="windows32"/>
                <ComboBoxItem Content="All Platforms" Tag="all"/>
            </ComboBox>
            
            <!-- Type Filter -->
            <ComboBox x:Name="DialogTypeComboBox"
                      Grid.Column="1"
                      Width="140"
                      Margin="12,0,0,0"
                      SelectionChanged="DialogTypeComboBox_SelectionChanged">
                <ComboBoxItem Content="All Types" Tag="all" IsSelected="True"/>
                <ComboBoxItem Content="MSI" Tag=".msi"/>
                <ComboBoxItem Content="MSIX" Tag=".msix"/>
                <ComboBoxItem Content="ZIP" Tag=".zip"/>
            </ComboBox>

            <!-- View Download Page Button -->
            <Button x:Name="DialogViewDownloadPage"
                    Grid.Column="3"
                    Click="DialogViewDownloadPage_Click"
                    Style="{StaticResource DefaultButtonStyle}"
                    Height="32"
                    Padding="12,0"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE71B;" FontSize="12"/>
                    <TextBlock Text="View Download Page" FontSize="12"/>
                </StackPanel>
            </Button>
        </Grid>
        <!-- Separator -->
        <Border Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Installers List with ScrollViewer -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      MaxHeight="360">
            <StackPanel>
                <ItemsControl x:Name="DialogInstallersList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:WindowsInstaller">
                            <Border Margin="0,3" 
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6" 
                                    Padding="16,8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" 
                                                Orientation="Horizontal" 
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Filename}" 
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Width="240"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Filename, Converter={StaticResource PlatformConverter}}" 
                                                   FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Width="70"/>
                                        <TextBlock FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind SizeBytes, Converter={StaticResource BytesToSizeConverter}}"/>
                                            <Run Text=" • "/>
                                            <Run Text="{x:Bind ReleaseDate}"/>
                                        </TextBlock>
                                    </StackPanel>
                                     <Grid Grid.Column="1" VerticalAlignment="Center">
                                         <!-- Download button (shown when not downloaded) -->
                                         <Button x:Name="DownloadBtn"
                                                 Click="DialogInstallerDownload_Click"
                                                 DataContext="{x:Bind}"
                                                 Style="{StaticResource AccentButtonStyle}"
                                                 Width="130"
                                                 Height="28"
                                                 Padding="12,0"
                                                 Visibility="{x:Bind local:DownloadDialog.GetDownloadButtonVisibility(Filename), Mode=OneTime}">
                                             <StackPanel Orientation="Horizontal" Spacing="4">
                                                 <FontIcon Glyph="&#xE896;" FontSize="12"/>
                                                 <TextBlock Text="Download" FontSize="12"/>
                                             </StackPanel>
                                         </Button>

                                         <!-- Open Actions (shown when downloaded) -->
                                         <SplitButton Click="OpenDownloadedInstaller_Click"
                                                      DataContext="{x:Bind}"
                                                      Width="130"
                                                      Height="28"
                                                      Visibility="{x:Bind local:DownloadDialog.GetOpenActionsVisibility(Filename), Mode=OneTime}">
                                             <StackPanel Orientation="Horizontal" Spacing="4">
                                                 <FontIcon Glyph="&#xE8E5;" FontSize="11" VerticalAlignment="Center"/>
                                                 <TextBlock Text="Open file" VerticalAlignment="Center" FontSize="11"/>
                                             </StackPanel>
                                             <SplitButton.Flyout>
                                                 <MenuFlyout Placement="Bottom">
                                                     <MenuFlyoutItem Text="Open folder"
                                                                     Click="OpenDownloadedFolder_Click"
                                                                     DataContext="{x:Bind}">
                                                         <MenuFlyoutItem.Icon>
                                                             <FontIcon Glyph="&#xE8DA;"/>
                                                         </MenuFlyoutItem.Icon>
                                                     </MenuFlyoutItem>
                                                 </MenuFlyout>
                                             </SplitButton.Flyout>
                                         </SplitButton>
                                     </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- No Installers Found Message -->
                <TextBlock x:Name="DialogNoInstallersMessage"
                           Text="No installers found with selected filters."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextAlignment="Center"
                           Margin="20,40,20,40"
                           Visibility="Collapsed"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Progress Section -->
        <StackPanel x:Name="DialogProgressPanel"
                    Spacing="8"
                    Visibility="Collapsed">
            <ProgressBar x:Name="DialogProgressBar"
                         IsIndeterminate="False"
                         Value="0"
                         Maximum="100"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="DialogProgressText"
                           Grid.Column="0"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="PauseResumeBtn"
                            Click="PauseResumeBtn_Click"
                            Style="{StaticResource DefaultButtonStyle}"
                            Padding="8,4"
                            FontSize="11">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="PauseResumeIcon" Glyph="&#xE769;" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PauseResumeText" Text="Pause" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DeleteDownloadBtn"
                            Click="DeleteDownloadBtn_Click"
                            Style="{StaticResource DefaultButtonStyle}"
                            Padding="8,4"
                            FontSize="11">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE74D;" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="Delete" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Completion Section -->
        <Grid x:Name="DialogCompletionPanel"
              Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CompletionMessageText" 
                       Grid.Column="0"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="OpenInstallerBtn"
                        Click="OpenInstallerBtn_Click"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="16,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8E5;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Open Installer" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="OpenFolderBtn"
                        Click="OpenFolderBtn_Click"
                        Style="{StaticResource DefaultButtonStyle}"
                        Padding="16,6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8DA;" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Open Folder" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
