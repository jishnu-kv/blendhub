<Page
    x:Class="BlendHub.Pages.SyncPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Pages"
    xmlns:models="using:BlendHub.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <CollectionViewSource x:Name="GroupedSyncItems" />
    </Page.Resources>

    <Grid Padding="32,32,32,0">


        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid x:Name="HeaderGrid" Grid.Row="0" Margin="0,0,0,20" ColumnDefinitions="*, Auto" RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Sync Settings"
                           FontSize="28"
                           FontFamily="Segoe UI Variable Display"
                           FontWeight="SemiBold"
                           AutomationProperties.HeadingLevel="Level1" />
                <TextBlock Grid.Row="1"
                           Text="Synchronize preferences and addons between installed versions."
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel x:Name="ActionPanel" Grid.Column="1" Grid.RowSpan="2" Orientation="Horizontal"
                Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Spacing="4">
                    <TextBlock x:Name="StatusText" Text="" FontWeight="Medium"
                        HorizontalAlignment="Right" FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="SyncProgressBar" Value="0" Maximum="100" Height="4"
                        MinWidth="120" IsIndeterminate="False" Opacity="0" />
                </StackPanel>
                <Button x:Name="StartSyncButton"
                    Click="StartSyncButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Height="36"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE895;" FontSize="14" />
                        <TextBlock Text="Start Sync" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Info Bars -->
        <StackPanel x:Name="InfoBarPanel" Grid.Row="1" Spacing="4" Margin="0,0,0,16" HorizontalAlignment="Stretch">
            <InfoBar x:Name="WarningInfoBar" IsOpen="False" IsClosable="True" Severity="Warning"
                Title="" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
            <InfoBar x:Name="ErrorInfoBar" IsOpen="False" IsClosable="True" Severity="Error"
                Title="" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
            <InfoBar x:Name="SuccessInfoBar" IsOpen="False" IsClosable="True" Severity="Success"
                Title="Sync Complete" Message="" Closed="InfoBar_Closed" HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
            VerticalContentAlignment="Stretch" Padding="0,0,0,0">
            <StackPanel Spacing="16" Padding="0">

                <StackPanel Spacing="6">
                    <!-- Source Blender Version -->
                    <controls:SettingsCard x:Name="SourceVersionCard"
                        Header="Source Blender Version"
                        Description="Choose which Blender version's settings you want to copy."
                        CornerRadius="4">
                        <controls:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE7B8;" />
                        </controls:SettingsCard.HeaderIcon>
                        <ComboBox x:Name="SourceVersionComboBox" MinWidth="200"
                            DisplayMemberPath="DisplayName"
                            SelectionChanged="SourceVersionComboBox_SelectionChanged"
                            HorizontalAlignment="Right" />
                    </controls:SettingsCard>

                    <!-- Target Blender Versions -->
                    <controls:SettingsExpander x:Name="TargetVersionsExpander"
                        Header="Target Blender Versions"
                        Description="Select the Blender versions you want to synchronize with the source."
                        IsExpanded="True"
                        CornerRadius="4">
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                HorizontalAlignment="Stretch" Padding="60,16" CornerRadius="0" Margin="0,0,0,0">
                                <ItemsRepeater x:Name="TargetVersionsListView"
                                    HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout MinItemWidth="160"
                                            Orientation="Horizontal" ItemsStretch="Fill" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:TargetVersionViewModel">
                                            <CheckBox Content="{x:Bind DisplayName}"
                                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                VerticalAlignment="Center" Margin="0,6,12,6" />
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>

                    <!-- Items to Sync -->
                    <controls:SettingsExpander x:Name="ItemsToSyncExpander" Header="Items to Sync"
                        Description="Select which parts of the configuration to synchronize."
                        IsExpanded="True"
                        CornerRadius="4">
                        <controls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE8A4;" />
                        </controls:SettingsExpander.HeaderIcon>
                        <controls:SettingsExpander.Items>
                            <controls:SettingsCard ContentAlignment="Vertical"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="60,16" CornerRadius="0" Margin="0,0,0,0">
                                <ItemsRepeater x:Name="SyncItemsRepeater"
                                    ItemsSource="{Binding Source={StaticResource GroupedSyncItems}}"
                                    HorizontalAlignment="Stretch">
                                    <ItemsRepeater.Layout>
                                        <StackLayout Orientation="Horizontal" Spacing="88" />
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Stretch">
                                                <TextBlock Text="{Binding Key}"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Margin="0,0,0,12"
                                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />

                                                <ItemsRepeater ItemsSource="{Binding Items}">
                                                    <ItemsRepeater.ItemTemplate>
                                                        <DataTemplate
                                                            x:DataType="models:ConfigItemViewModel">
                                                            <CheckBox Content="{x:Bind Name}"
                                                                IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                                IsEnabled="{x:Bind IsExists}"
                                                                Margin="0,2,0,2"
                                                                ToolTipService.ToolTip="{x:Bind TooltipText}" />
                                                        </DataTemplate>
                                                    </ItemsRepeater.ItemTemplate>
                                                </ItemsRepeater>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>
                            </controls:SettingsCard>
                        </controls:SettingsExpander.Items>
                    </controls:SettingsExpander>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
