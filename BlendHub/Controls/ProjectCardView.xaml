<UserControl
    x:Class="BlendHub.Controls.ProjectCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Controls"
    xmlns:models="using:BlendHub.Models"
    xmlns:pages="using:BlendHub.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- ========================================
		     FOLDER HEADER TEMPLATE
		     ======================================== -->
        <DataTemplate x:Key="FolderHeaderTemplate" x:DataType="models:FolderViewModel">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Expand/Collapse Icon -->
                <FontIcon Glyph="{x:Bind ExpandIcon, Mode=OneWay}"
                          FontSize="10"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

                <!-- Folder Icon -->
                <Image Grid.Column="1"
                       Source="{x:Bind FolderIcon, Mode=OneWay}"
                       Width="20"
                       Height="20"
                       VerticalAlignment="Center" />

                <!-- Folder Name -->
                <TextBlock Grid.Column="2"
                           Text="{x:Bind Name}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <!-- Item Count -->
                <TextBlock Grid.Column="3"
                           Text="{x:Bind ItemCountText}"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
            </Grid>
        </DataTemplate>

        <!-- ========================================
		     FILE TEMPLATE
		     ======================================== -->
        <DataTemplate x:Key="FileTemplate"
                      x:DataType="models:FileViewModel">
            <Grid Padding="0,4"
                  DoubleTapped="FileItem_DoubleTapped"
                  Background="Transparent"
                  AutomationProperties.Name="{x:Bind Name}">
                <Grid.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Open File"
                                        Click="OpenFile_Click"
                                        Tag="{x:Bind FullPath}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8A7;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Open Folder"
                                        Click="OpenContainingFolder_Click"
                                        Tag="{x:Bind FullPath}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE8DA;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem Text="Delete"
                                        Click="DeleteFile_Click"
                                        Tag="{x:Bind FullPath}"
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Grid.ContextFlyout>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <Grid Width="20" Height="20" Margin="0,0,12,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="{x:Bind IconSource, Mode=OneWay}"
                           Stretch="Uniform"
                           Visibility="{x:Bind IconVisibility, Mode=OneWay}" />
                    <FontIcon Glyph="&#xE8A5;"
                              FontSize="16"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              Visibility="{x:Bind FallbackIconVisibility, Mode=OneWay}" />
                </Grid>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind Name}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2"
                           Text="{x:Bind ModifiedDateText}"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3"
                           Text="{x:Bind SizeText}"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <!-- ========================================
		     FOLDER TEMPLATE
		     ======================================== -->
        <DataTemplate x:Key="FolderTemplate"
                      x:DataType="models:FolderViewModel">
            <StackPanel Margin="0">
                <Button Click="FolderHeader_Click"
                        Tag="{x:Bind}"
                        Style="{StaticResource SubtleButtonStyle}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Content="{x:Bind}"
                        ContentTemplate="{StaticResource FolderHeaderTemplate}"
                        Padding="8,6">
                    <Button.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Open Folder"
                                            Click="OpenContainingFolder_Click"
                                            Tag="{x:Bind FullPath}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8DA;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Delete"
                                            Click="DeleteFile_Click"
                                            Tag="{x:Bind FullPath}"
                                            Foreground="{ThemeResource SystemFillColorCriticalBrush}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.ContextFlyout>
                </Button>

                <ItemsControl ItemsSource="{x:Bind Subfolders}"
                              Visibility="{x:Bind ContentVisibility, Mode=OneWay}"
                              Padding="24,0,0,0"
                              Margin="24,4,0,0"
                              HorizontalContentAlignment="Stretch">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}"
                                            ContentTemplate="{StaticResource FolderTemplate}"
                                            HorizontalContentAlignment="Stretch"
                                            HorizontalAlignment="Stretch" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ListView ItemsSource="{x:Bind FilesOnly}"
                          ItemTemplate="{StaticResource FileTemplate}"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          Visibility="{x:Bind ContentVisibility, Mode=OneWay}"
                          Padding="24,0,0,0"
                          Margin="0"
                          BorderThickness="0"
                          ToolTipService.ToolTip="Double-click any file to open it directly. Right-click or use the actions button for more options!">
                </ListView>
            </StackPanel>
        </DataTemplate>

        <!-- ========================================
		     NOTE TEMPLATE
		     ======================================== -->
        <DataTemplate x:Key="NoteTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="320"
                    MinHeight="160"
                    Margin="0,0,16,16">
                <Grid Padding="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Heading -->
                    <TextBlock Text="{Binding Heading}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                    
                    <!-- Content -->
                    <TextBlock Grid.Row="1" Text="{Binding Content}" TextWrapping="Wrap" Margin="0,4,0,16" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Top" />
                    
                    <!-- Divider line -->
                    <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-20,0,-20,12" />
                    
                    <!-- Footer -->
                    <Grid Grid.Row="3" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE787;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{Binding CreatedAtString}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SubtleButtonStyle}" Padding="6">
                                <FontIcon Glyph="&#xE712;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditItem_Click" Tag="{Binding}" />
                                        <MenuFlyoutItem Text="Delete" Icon="Delete" Click="DeleteItem_Click" Tag="{Binding}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ========================================
		     PROJECT FILE CARD TEMPLATE
		     ======================================== -->
        <DataTemplate x:Key="ProjectFileTemplate">
            <Grid Padding="0,2" AutomationProperties.Name="{Binding Name}" DoubleTapped="ProjectFileItem_DoubleTapped" Background="Transparent" HorizontalAlignment="Stretch"
                  ToolTipService.ToolTip="Double-click any file to open it directly. Right-click or use the actions button for more options!">
                <Grid.ContextFlyout>
                    <MenuFlyout Opening="FileMenuFlyout_Opening" />
                </Grid.ContextFlyout>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <!-- Column 0: Thumbnail -->
                <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/blender_logo.png"
                           Height="16"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Grid>

                <!-- Column 1: Name -->
                <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                           HorizontalAlignment="Left" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />

                <!-- Column 2: Blender Version -->
                <TextBlock Grid.Column="2" Text="{Binding ProgramName}" Visibility="{Binding ProgramNameVisibility}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>

                <!-- Column 3: Size -->
                <TextBlock Grid.Column="3" Text="{Binding Size}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>

                <!-- Column 4: Modified -->
                <TextBlock Grid.Column="4" Text="{Binding Modified}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>

                <!-- Column 5: Actions -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <Button Style="{StaticResource SubtleButtonStyle}" Padding="6" Height="32" Width="32" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE712;" FontSize="12" />
                        <Button.Flyout>
                            <MenuFlyout Opening="FileMenuFlyout_Opening" />
                        </Button.Flyout>
                    </Button>
                    <Button Click="RemoveCustomFileBtn_Click"
                            Tag="{Binding}"
                            Visibility="{Binding CustomFileVisibility}"
                            Padding="6,4">
                        <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ========================================
		     LAUNCHER FILE CARD TEMPLATE (no Blender Version column)
		     ======================================== -->
        <DataTemplate x:Key="LauncherFileTemplate">
            <Grid Padding="0,2" AutomationProperties.Name="{Binding Name}" Tag="Launcher" DoubleTapped="ProjectFileItem_DoubleTapped" Background="Transparent" HorizontalAlignment="Stretch"
                  ToolTipService.ToolTip="Double-click any file to open it directly. Right-click or use the actions button for more options!">
                <Grid.ContextFlyout>
                    <MenuFlyout Opening="FileMenuFlyout_Opening" />
                </Grid.ContextFlyout>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="2.5*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="80" />
                </Grid.ColumnDefinitions>

                <!-- Column 0: Thumbnail -->
                <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="{Binding IconSource}"
                           Height="16"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IconVisibility}" />
                    <FontIcon Glyph="&#xE8A5;"
                              FontSize="18"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Visibility="{Binding FallbackIconVisibility}" />
                </Grid>

                <!-- Column 1: Name -->
                <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                           HorizontalAlignment="Left" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />

                <!-- Column 2: Program/Launcher -->
                <TextBlock Grid.Column="2" Text="{Binding ProgramName}" Visibility="{Binding ProgramNameVisibility}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>

                <!-- Column 3: Size -->
                <TextBlock Grid.Column="3" Text="{Binding Size}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>

                <!-- Column 4: Modified -->
                <TextBlock Grid.Column="4" Text="{Binding Modified}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>

                <!-- Column 5: Actions -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <Button Style="{StaticResource SubtleButtonStyle}" Padding="6" Height="32" Width="32" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE712;" FontSize="12" />
                        <Button.Flyout>
                            <MenuFlyout Opening="FileMenuFlyout_Opening" />
                        </Button.Flyout>
                    </Button>
                    <Button Click="RemoveCustomFileBtn_Click"
                            Tag="{Binding}"
                            Visibility="{Binding CustomFileVisibility}"
                            Padding="6,4">
                        <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- ========================================
		     TODO TEMPLATE
		     ======================================== -->
        <DataTemplate x:Key="TodoTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Stretch"
                    MinHeight="140">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Heading}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorPrimaryBrush}" Margin="0,0,8,8" />
                        <Border Grid.Column="1" Background="{Binding PriorityBackgroundColor}" CornerRadius="4" Padding="6,2" Visibility="{Binding PriorityVisibility}" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE7C1;" FontSize="10" Foreground="{Binding PriorityIconColor}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PriorityText}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Foreground="{Binding PriorityTextColor}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,12" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Top" TextDecorations="{Binding TextDecoration}" Foreground="{Binding TextColorBrush}" />
                    </StackPanel>
                    
                    <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="-16,0,-16,12" />
                    
                    <Grid Grid.Row="3" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" Spacing="6" Visibility="{Binding DueDateVisibility}" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xF763;" FontSize="14" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBlock Text="{Binding DueDateString}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SubtleButtonStyle}" Padding="6">
                                <FontIcon Glyph="&#xE712;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Edit" Icon="Edit" Click="EditItem_Click" Tag="{Binding}" />
                                        <MenuFlyoutItem Text="Delete" Icon="Delete" Click="DeleteItem_Click" Tag="{Binding}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="ItemsPanelTemplate">
            <VariableSizedWrapGrid Orientation="Horizontal" />
        </ItemsPanelTemplate>
        
        <models:ProjectItemTemplateSelector x:Key="ItemSelector"
                                            NoteTemplate="{StaticResource NoteTemplate}"
                                            TodoTemplate="{StaticResource TodoTemplate}" />
    </UserControl.Resources>

    <Expander x:Name="CardExpander"
              MinHeight="74"
              Margin="0,0,0,6"
              CornerRadius="6"
              Opacity="{x:Bind models:Project.GetOpacity(Project.FolderExists)}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch">

        <Expander.Header>
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Thumbnail -->
                    <Border Grid.Column="0"
                            CornerRadius="8"
                            Width="48"
                            Height="48"
                            VerticalAlignment="Center"
                            Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}">
                        <Image x:Name="ThumbnailImage"
                               Loaded="Thumbnail_Loaded"
                               Stretch="Uniform" />
                    </Border>

                    <!-- Project Info Vertical Layout -->
                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <!-- First: Heading -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Project.Name, Mode=OneWay}"
                                       Style="{StaticResource BodyLargeStrongTextBlockStyle}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind Project.StatusText, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlErrorTextForegroundBrush}"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       Visibility="{x:Bind models:Project.GetMissingVisibility(Project.FolderExists), Mode=OneWay}" />
                        </StackPanel>
 
                        <!-- Second: Path -->
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Project.Path, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       MaxWidth="380" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" Margin="16,0,0,0">
                    <Button Style="{StaticResource SubtleButtonStyle}" Padding="6" Visibility="{x:Bind GetExistsVisibility(Project.FolderExists), Mode=OneWay}" Width="40" Height="40" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE712;" FontSize="16" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open folder" Icon="OpenLocal" Click="OpenProjectFolderMenu_Click" />
                                <MenuFlyoutItem Text="Edit Project" Icon="Edit" Click="EditProjectMenu_Click" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Delete project" Icon="Delete" Click="DeleteProjectMenu_Click" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Click="LocateProject_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="160"
                            Visibility="{x:Bind models:Project.GetMissingVisibility(Project.FolderExists), Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8DA;" FontSize="14" />
                            <TextBlock Text="Locate Project" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Expander.Header>

        <Expander.Content>
            <Grid RowSpacing="12" Padding="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Height="40" VerticalAlignment="Center">
                    <toolkit:Segmented x:Name="ContentSelectorBar"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       MinHeight="32"
                                       SelectionChanged="ContentSelectorBar_SelectionChanged">
                        <toolkit:Segmented.Resources>
                            <Style TargetType="toolkit:SegmentedItem">
                                <Setter Property="MinHeight" Value="32" />
                            </Style>
                        </toolkit:Segmented.Resources>
                        <toolkit:SegmentedItem x:Name="FilesTab" Tag="Projects">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xF158;" FontSize="14" />
                                <TextBlock x:Name="FilesTabText" Text="Projects" />
                            </StackPanel>
                        </toolkit:SegmentedItem>
                        <toolkit:SegmentedItem x:Name="DirectoriesTab" Tag="Directories">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                <TextBlock x:Name="DirectoriesTabText" Text="Directories" />
                            </StackPanel>
                        </toolkit:SegmentedItem>
                        <toolkit:SegmentedItem x:Name="LaunchersTab" Tag="Launchers">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE7C3;" FontSize="14" />
                                <TextBlock x:Name="LaunchersTabText" Text="Launchers" />
                            </StackPanel>
                        </toolkit:SegmentedItem>
                        <toolkit:SegmentedItem x:Name="NotesTab" Tag="Notes">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE70B;" FontSize="14" />
                                <TextBlock x:Name="NotesTabText" Text="Notes" />
                            </StackPanel>
                        </toolkit:SegmentedItem>
                        <toolkit:SegmentedItem x:Name="TasksTab" Tag="Tasks">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xF7EC;" FontSize="14" />
                                <TextBlock x:Name="TasksTabText" Text="Tasks" />
                            </StackPanel>
                        </toolkit:SegmentedItem>
                    </toolkit:Segmented>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <AutoSuggestBox x:Name="GlobalSearchBox"
                                        PlaceholderText="Search..."
                                        Width="240"
                                        Height="32"
                                        VerticalAlignment="Center"
                                        IsEnabled="False"
                                        QueryIcon="Find"
                                        TextChanged="GlobalSearchBox_TextChanged" />

                        <Button x:Name="AddNoteBtn"
                                Visibility="Collapsed"
                                Click="AddProjectItem_Click"
                                Height="32"
                                VerticalAlignment="Center"
                                Padding="12,0"
                                MinWidth="100">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE70B;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Add Item" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="AddFileBtn"
                                Visibility="Collapsed"
                                Click="AddCustomFile_Click"
                                Height="32"
                                VerticalAlignment="Center"
                                Padding="12,0"
                                MinWidth="100">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE710;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Add File" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="RefreshDirectoriesBtn"
                                Visibility="Collapsed"
                                Click="RefreshLocations_Click"
                                Height="32"
                                VerticalAlignment="Center"
                                Padding="12,0"
                                MinWidth="100">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE72C;" FontSize="12" VerticalAlignment="Center" />
                                <TextBlock Text="Refresh" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="450"
                              Padding="0,12,0,0">
                    <ContentControl x:Name="ContentContainer" HorizontalContentAlignment="Stretch" />
                </ScrollViewer>
            </Grid>
        </Expander.Content>
    </Expander>
</UserControl>
