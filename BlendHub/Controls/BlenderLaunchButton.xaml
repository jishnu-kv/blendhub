<UserControl
    x:Class="BlendHub.Controls.BlenderLaunchButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlendHub.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <SplitButton x:Name="MainSplitButton"
                 Click="MainSplitButton_Click"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <FontIcon Glyph="{x:Bind IconGlyph, Mode=OneWay}" FontSize="14" />
            <TextBlock Text="{x:Bind Text, Mode=OneWay}" />
        </StackPanel>
        <SplitButton.Flyout>
            <MenuFlyout Opening="MenuFlyout_Opening" Placement="Bottom" />
        </SplitButton.Flyout>
    </SplitButton>
</UserControl>
